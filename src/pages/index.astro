<style>
/* ══ HERO ══ */
#hero{min-height:100vh;position:relative;overflow:hidden;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:100px 52px 80px}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 65% 55% at 50% 48%,rgba(232,0,106,.22) 0%,transparent 60%),radial-gradient(ellipse 32% 32% at 15% 15%,rgba(120,0,160,.14) 0%,transparent 55%),radial-gradient(ellipse 32% 32% at 85% 15%,rgba(240,200,74,.08) 0%,transparent 55%),linear-gradient(180deg,#1a0820 0%,#280c30 50%,#1a0820 100%)}
.hero-vignette{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%,transparent 30%,rgba(0,0,0,.82) 100%);z-index:1}
.rose{position:absolute;z-index:2;top:50%;left:50%;transform:translate(-50%,-50%);width:min(90vmin,800px);height:min(90vmin,800px);pointer-events:none;animation:rbreath 6s ease-in-out infinite}
@keyframes rbreath{0%,100%{opacity:.22;filter:drop-shadow(0 0 18px rgba(224,0,154,.18))}50%{opacity:.36;filter:drop-shadow(0 0 48px rgba(255,100,180,.72))}}
.arch{position:absolute;z-index:3;top:50%;left:50%;transform:translate(-50%,-50%);width:min(52vmin,460px);height:min(72vmin,630px);pointer-events:none;animation:archglow 4.5s ease-in-out infinite}
@keyframes archglow{0%,100%{filter:drop-shadow(0 0 8px rgba(224,0,154,.28))}50%{filter:drop-shadow(0 0 28px rgba(224,0,154,.58))}}
.lh{position:absolute;left:0;right:0;height:2px;pointer-events:none;z-index:4;background:linear-gradient(90deg,transparent,rgba(240,200,74,.32),rgba(224,0,154,.52),rgba(240,200,74,.32),transparent)}
.lv{position:absolute;top:0;bottom:0;width:2px;pointer-events:none;z-index:4;background:linear-gradient(180deg,transparent,rgba(224,0,154,.32),rgba(240,200,74,.38),rgba(224,0,154,.32),transparent)}
.hero-inner{position:relative;z-index:10;text-align:center;display:flex;flex-direction:column;align-items:center}
.hero-cross{margin-bottom:22px;filter:drop-shadow(0 0 14px rgba(224,0,154,.65));animation:cpulse 3.5s ease-in-out infinite}
@keyframes cpulse{0%,100%{filter:drop-shadow(0 0 14px rgba(224,0,154,.55))}50%{filter:drop-shadow(0 0 32px rgba(255,0,200,.95))}}
.eyebrow{font-family:var(--font-heading);font-size:.48rem;letter-spacing:.55em;text-transform:uppercase;color:var(--gold);margin-bottom:16px;display:flex;align-items:center;gap:14px;opacity:0;animation:fadeup .8s ease .3s forwards}
.er{height:1px;width:42px}.erl{background:linear-gradient(90deg,transparent,var(--gold))}.err{background:linear-gradient(270deg,transparent,var(--gold))}
@keyframes fadeup{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}
.hero-title{font-family:var(--font-display);font-size:clamp(3.5rem,11.5vw,10rem);font-weight:300;font-style:italic;line-height:.9;margin-bottom:10px;animation:titlereveal .9s cubic-bezier(.77,0,.175,1) .1s both}
@keyframes titlereveal{from{opacity:0;transform:translateY(28px) skewY(2deg)}to{opacity:1;transform:none}}
.t-little{display:block;color:var(--mg5);text-shadow:0 0 80px rgba(255,120,190,.78),0 2px 0 rgba(0,0,0,.5)}
.t-conf{display:block;background:linear-gradient(135deg,var(--mg5) 0%,var(--mg4) 20%,var(--mg3) 40%,var(--gold2) 58%,var(--mg3) 75%,var(--mg5) 100%);background-size:300% 300%;-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:shimmer-t 5s ease-in-out infinite;filter:drop-shadow(0 0 40px rgba(255,100,180,.68))}
@keyframes shimmer-t{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
.title-line{display:block;overflow:hidden}
.hero-tagline{font-family:var(--font-display);font-style:italic;font-weight:300;font-size:clamp(.85rem,1.7vw,1.1rem);color:rgba(255,180,220,.82);letter-spacing:.26em;margin:16px 0 38px;opacity:0;animation:fadeup .8s ease .5s forwards}
.hero-btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;opacity:0;animation:fadeup .8s ease .7s forwards}
.scroll-cue{position:absolute;bottom:28px;left:50%;transform:translateX(-50%);z-index:10;display:flex;flex-direction:column;align-items:center;gap:7px;opacity:0;animation:fadeup .8s ease 1s forwards}
.sc-l{width:1px;height:46px;background:linear-gradient(180deg,transparent,var(--mg2));animation:scg 2.3s ease-in-out infinite}
@keyframes scg{0%{height:0;opacity:0}55%{height:46px;opacity:1}100%{height:46px;opacity:0}}
.sc-t{font-family:var(--font-heading);font-size:.45rem;letter-spacing:.36em;text-transform:uppercase;color:rgba(255,100,180,.65)}

/* ══ FEATURED ══ */
.feat-content{padding:80px 52px;background:var(--dark2);position:relative;overflow:hidden}
.big-panel{display:grid;grid-template-columns:1fr 4px 1fr;border:2px solid rgba(224,0,154,.22);overflow:hidden;transition:border-color .38s;text-decoration:none;position:relative;margin-bottom:3px}
.big-panel:hover{border-color:rgba(224,0,154,.7)}
.big-panel:hover .bp-glow{opacity:1}
.big-panel:hover .bp-title{color:#fff;text-shadow:0 0 20px rgba(255,100,180,.68)}
.big-panel:hover .bp-read-line{width:48px}
.big-panel:hover .bp-read{gap:14px}
.big-panel:hover .bp-glass{transform:translateY(-12px) rotate(2deg)}
.bp-vis{background:var(--dark3);min-height:380px;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
.bp-vis-bg{position:absolute;inset:0;background:radial-gradient(ellipse at 40% 50%,rgba(224,0,154,.26) 0%,transparent 60%);animation:bfglow 4.5s ease-in-out infinite;z-index:1}
@keyframes bfglow{0%,100%{opacity:.7}50%{opacity:1}}
.bp-glow{position:absolute;inset:0;background:rgba(232,0,106,.08);opacity:0;transition:opacity .38s;z-index:1}
.bp-glass{position:relative;z-index:2;transition:transform .5s ease;filter:drop-shadow(0 0 22px rgba(224,0,154,.3))}
.bp-badge{position:absolute;top:20px;left:20px;z-index:5;font-family:var(--font-heading);font-size:.45rem;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);border:1px solid rgba(240,200,74,.4);background:rgba(3,1,10,.85);padding:5px 12px;backdrop-filter:blur(10px)}
/* FIX: gold corners as real divs (not ::before/::after) to avoid z-index fight with bp-vis-bg */
.bp-corner-tl{position:absolute;top:13px;left:13px;width:22px;height:22px;border-top:1.5px solid rgba(240,200,74,.5);border-left:1.5px solid rgba(240,200,74,.5);z-index:5;pointer-events:none}
.bp-corner-br{position:absolute;bottom:13px;right:13px;width:22px;height:22px;border-bottom:1.5px solid rgba(240,200,74,.5);border-right:1.5px solid rgba(240,200,74,.5);z-index:5;pointer-events:none}
.bp-divider{background:var(--lead);border-left:1px solid rgba(240,200,74,.22);border-right:1px solid rgba(240,200,74,.22)}
.bp-body{background:var(--dark4);padding:44px 40px;display:flex;flex-direction:column;justify-content:center;position:relative}
.bp-body::before{content:'';position:absolute;left:0;top:10%;bottom:10%;width:1px;background:linear-gradient(180deg,transparent,rgba(224,0,154,.32),transparent)}
.bp-cat{font-family:var(--font-heading);font-size:.44rem;letter-spacing:.2em;text-transform:uppercase;color:var(--mg3);margin-bottom:14px;display:flex;align-items:center;gap:10px}
.bp-spoiler{font-size:.42rem;background:rgba(224,0,154,.15);border:1px solid rgba(224,0,154,.35);padding:2px 7px}
.bp-title{font-family:var(--font-display);font-size:1.9rem;font-weight:400;color:var(--mg5);line-height:1.2;margin-bottom:14px;transition:all .3s}
.bp-desc{font-style:italic;font-size:.92rem;color:rgba(255,180,220,.82);line-height:1.88;margin-bottom:18px}
.bp-meta{font-family:var(--font-heading);font-size:.45rem;letter-spacing:.12em;color:rgba(220,160,200,.68);margin-bottom:14px}
.bp-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:18px}
.bp-tag{font-family:var(--font-heading);font-size:.42rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,100,180,.72);border:1px solid rgba(224,0,154,.15);padding:2px 8px}
.bp-read{font-family:var(--font-heading);font-size:.46rem;letter-spacing:.2em;text-transform:uppercase;color:var(--mg3);display:flex;align-items:center;gap:10px;transition:gap .3s}
.bp-read-line{width:26px;height:1px;background:linear-gradient(90deg,var(--mg),var(--gold));transition:width .3s}
.bp-empty{padding:60px 0;text-align:center;font-family:var(--font-display);font-style:italic;color:rgba(255,180,220,.78);font-size:1rem}

/* Post mosaic — rectangles + squares */
.post-mosaic{display:grid;grid-template-columns:repeat(3,1fr);grid-auto-rows:140px;gap:3px;background:rgba(232,0,106,.08)}
.pm-card-4{grid-column:span 2}   /* wide rectangle */
.pm-card-1{grid-row:span 2}      /* tall square */
.pm-card{background:var(--dark3);position:relative;overflow:hidden;display:flex;flex-direction:column;text-decoration:none;cursor:pointer;transition:background .25s;border:1px solid rgba(224,0,154,.08)}
.pm-card:hover{background:rgba(42,14,52,.97)}
.pm-card:hover .pm-title{color:#fff}
.pm-card:hover .pm-arrow{opacity:1;transform:translateX(5px)}
.pm-card:hover .pm-corner-tl,.pm-card:hover .pm-corner-br{opacity:1}
.pm-card:hover .pm-shine{left:120%}
.pm-top-bar{height:5px;flex-shrink:0;background:linear-gradient(90deg,var(--mg),var(--mg2),var(--mg))}
.pm-card-2 .pm-top-bar{background:linear-gradient(90deg,var(--gold),var(--mg3),var(--gold))}
.pm-card-3 .pm-top-bar{background:linear-gradient(90deg,var(--v2),var(--mg),var(--v2))}
.pm-card-4 .pm-top-bar{background:linear-gradient(90deg,var(--mg2),var(--gold),var(--mg2))}
.pm-card-5 .pm-top-bar{background:linear-gradient(90deg,var(--t),var(--mg3),var(--t))}
.pm-card-6 .pm-top-bar{background:linear-gradient(90deg,var(--mg),var(--v2),var(--mg))}
.pm-body{padding:14px 16px;flex:1;display:flex;flex-direction:column;justify-content:center;min-width:0}
.pm-cat{font-family:var(--font-heading);font-size:.42rem;letter-spacing:.16em;text-transform:uppercase;color:var(--mg3);margin-bottom:7px}
.pm-title{font-family:var(--font-display);font-size:.98rem;color:var(--mg5);line-height:1.3;margin-bottom:6px;transition:color .25s;/* prevent overflow in grid */overflow:hidden;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical}
.pm-meta{font-family:var(--font-heading);font-size:.42rem;letter-spacing:.1em;color:rgba(220,160,200,.65)}
.pm-arrow{position:absolute;bottom:10px;right:12px;color:var(--mg);opacity:0;transition:all .25s}
.pm-corner-tl{position:absolute;top:14px;left:10px;width:12px;height:12px;border-top:1px solid rgba(240,200,74,.5);border-left:1px solid rgba(240,200,74,.5);opacity:0;transition:opacity .25s;pointer-events:none}
.pm-corner-br{position:absolute;bottom:10px;right:10px;width:12px;height:12px;border-bottom:1px solid rgba(240,200,74,.5);border-right:1px solid rgba(240,200,74,.5);opacity:0;transition:opacity .25s;pointer-events:none}
.pm-shine{position:absolute;top:0;left:-100%;width:55%;height:100%;background:linear-gradient(90deg,transparent,rgba(224,0,154,.06),transparent);transition:left .55s ease;pointer-events:none}
.feat-view-all{text-align:center;margin-top:32px}
/* FIX: btn-lead scoped here — does NOT use .btn to avoid colliding with Base.astro nav styles */
.btn-lead{font-family:var(--font-heading);font-size:.52rem;letter-spacing:.2em;text-transform:uppercase;padding:13px 30px;cursor:pointer;transition:all .3s;position:relative;overflow:hidden;background:transparent;color:var(--gold);border:1px solid rgba(240,200,74,.38);display:inline-flex;align-items:center;text-decoration:none}
.btn-lead::before{content:'';position:absolute;inset:0;background:rgba(240,200,74,.1);transform:scaleX(0);transform-origin:left;transition:transform .32s cubic-bezier(.77,0,.175,1)}
.btn-lead:hover::before{transform:scaleX(1)}
.btn-lead:hover{border-color:rgba(240,200,74,.7);transform:translateY(-2px)}
.btn-lead span{position:relative;z-index:1}

/* ══ CATEGORIES ══ */
.cat-content{padding:74px 52px;background:var(--dark);position:relative;overflow:hidden}
.cat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:4px;background:rgba(224,0,154,.06);margin-top:44px}
.cat{background:var(--dark3);padding:42px 18px 36px;text-align:center;cursor:pointer;position:relative;overflow:hidden;transition:background .28s;border-top:4px solid transparent;text-decoration:none;display:block}
.cat-1{border-top-color:var(--mg)}.cat-2{border-top-color:var(--gold)}.cat-3{border-top-color:var(--v2)}.cat-4{border-top-color:var(--t)}
.cat-glow{position:absolute;inset:0;opacity:0;transition:opacity .28s;pointer-events:none}
.cat-1 .cat-glow{background:radial-gradient(ellipse at 50% 0%,rgba(224,0,154,.18),transparent 68%)}
.cat-2 .cat-glow{background:radial-gradient(ellipse at 50% 0%,rgba(240,200,74,.14),transparent 68%)}
.cat-3 .cat-glow{background:radial-gradient(ellipse at 50% 0%,rgba(184,64,232,.16),transparent 68%)}
.cat-4 .cat-glow{background:radial-gradient(ellipse at 50% 0%,rgba(0,200,212,.12),transparent 68%)}
.cat::before{content:'';position:absolute;top:12px;right:12px;width:16px;height:16px;border-top:1px solid rgba(240,200,74,.5);border-right:1px solid rgba(240,200,74,.5);opacity:0;transition:opacity .28s}
.cat::after{content:'';position:absolute;bottom:12px;left:12px;width:16px;height:16px;border-bottom:1px solid rgba(240,200,74,.5);border-left:1px solid rgba(240,200,74,.5);opacity:0;transition:opacity .28s}
.cat:hover{background:rgba(42,16,56,.96)}
.cat:hover .cat-glow,.cat:hover::before,.cat:hover::after{opacity:1}
.cat:hover .cat-iw{transform:scale(1.12) translateY(-5px)}
.cat:hover .cat-n{color:#fff}
.cat-iw{transition:transform .3s cubic-bezier(.34,1.56,.64,1);margin-bottom:15px;display:flex;justify-content:center;position:relative;z-index:2}
.cat-n{font-family:var(--font-display);font-size:1.02rem;font-weight:400;color:var(--mg5);letter-spacing:.08em;margin-bottom:6px;transition:color .28s;position:relative;z-index:2}
.cat-c{font-family:var(--font-heading);font-size:.45rem;letter-spacing:.14em;color:var(--mg3);opacity:.6;position:relative;z-index:2}

/* ══ MAGIC CARDS ══ */
.mc-content{padding:80px 52px;background:var(--dark3)}
.mc-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:16px;margin-top:44px}
.mc-card{height:300px;cursor:pointer;perspective:1200px;text-decoration:none;display:block}
.mc-inner{width:100%;height:100%;position:relative;transform-style:preserve-3d;-webkit-transform-style:preserve-3d;transition:transform .8s cubic-bezier(.77,0,.18,1)}
.mc-card:hover .mc-inner{transform:rotateY(180deg)}
/* FLIP FIX: backface-visibility must work — use solid hex colors, NO rgba, NO transparency */
.mc-f,.mc-b{
  position:absolute;inset:0;
  backface-visibility:hidden;-webkit-backface-visibility:hidden;
  border:1px solid rgba(232,0,106,.28);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:24px 18px;overflow:hidden;
}
/* Fully opaque solid backgrounds — transparency breaks backface-visibility on many browsers */
.mc-f{background:#42184e;}
/* Override per Noir Rose palette */
body.light .mc-f{background:#ffffff !important;}
.mc-f::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 30%,rgba(224,0,154,.12) 0%,transparent 65%);pointer-events:none}
.mc-f::after{content:'';position:absolute;top:10px;right:10px;width:16px;height:16px;border-top:1px solid rgba(240,200,74,.42);border-right:1px solid rgba(240,200,74,.42);pointer-events:none}
.mc-b{background:#361240;transform:rotateY(180deg);-webkit-transform:rotateY(180deg);border-color:rgba(232,0,106,.55);box-shadow:inset 0 0 40px rgba(232,0,106,.1)}
.mc-b::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%,rgba(224,0,154,.15) 0%,transparent 68%)}
.mc-f-1,.mc-b-1{border-top:3px solid var(--mg)}
.mc-f-2,.mc-b-2{border-top:3px solid var(--gold)}
.mc-f-3,.mc-b-3{border-top:3px solid var(--v2)}
.mc-f-4,.mc-b-4{border-top:3px solid var(--t)}
.mc-f-5,.mc-b-5{border-top:3px solid var(--mg2)}
.mc-sym{margin-bottom:14px;filter:drop-shadow(0 0 12px rgba(224,0,154,.55));animation:sympulse 3s ease-in-out infinite;position:relative;z-index:2}
@keyframes sympulse{0%,100%{filter:drop-shadow(0 0 12px rgba(224,0,154,.55))}50%{filter:drop-shadow(0 0 24px rgba(255,0,200,.9))}}
.mc-lbl{font-family:var(--font-heading);font-size:.44rem;letter-spacing:.22em;text-transform:uppercase;color:var(--mg3);margin-bottom:5px;position:relative;z-index:2}
.mc-nm{font-family:var(--font-display);font-size:1.15rem;font-style:italic;color:var(--mg5);text-align:center;line-height:1.3;position:relative;z-index:2}
.mc-hint{font-family:var(--font-heading);font-size:.42rem;letter-spacing:.2em;color:rgba(255,100,180,.65);margin-top:12px;text-transform:uppercase;position:relative;z-index:2;animation:hblink 2s ease-in-out infinite}
@keyframes hblink{0%,100%{opacity:.38}50%{opacity:.9}}
.mc-b-sym{margin-bottom:12px;filter:drop-shadow(0 0 16px rgba(224,0,154,.7));position:relative;z-index:2}
.mc-b-title{font-family:var(--font-display);font-size:1.2rem;font-weight:600;font-style:italic;color:var(--mg4);margin-bottom:8px;text-align:center;position:relative;z-index:2}
.mc-b-text{font-style:italic;font-size:.82rem;color:rgba(255,180,220,.82);line-height:1.75;text-align:center;position:relative;z-index:2}
.mc-b-count{font-family:var(--font-heading);font-size:.45rem;letter-spacing:.18em;color:var(--gold);margin-top:12px;text-transform:uppercase;position:relative;z-index:2}
.mc-count-live{font-family:var(--font-heading);font-size:.44rem;letter-spacing:.14em;color:var(--mg3);margin-top:6px;position:relative;z-index:2}
.mc-b-cta{font-family:var(--font-heading);font-size:.44rem;letter-spacing:.18em;text-transform:uppercase;color:var(--mg3);margin-top:14px;position:relative;z-index:2;transition:color .2s}
.mc-card-link .mc-b:hover .mc-b-cta,.mc-card-link:hover .mc-b-cta{color:var(--mg4)}
/* mc-card as <a> — remove default link underline */
.mc-card-link{text-decoration:none;}

/* ══ QUOTE ══ */
.quote-content{padding:0;background:var(--dark2);position:relative;overflow:hidden}
.q-strip{height:28px;overflow:hidden;flex-shrink:0}
/* FIX: explicit grid-template-columns — was missing, browser defaulted to 1 column */
.q-body{display:grid;grid-template-columns:200px 1fr 200px;align-items:center;padding:64px 0}
.q-panel-side{display:flex;align-items:center;justify-content:center;padding:0 24px;opacity:.55;transition:opacity .3s}
.q-panel-side:hover{opacity:.82}
.q-center{text-align:center;display:flex;flex-direction:column;align-items:center;padding:0 48px;position:relative;z-index:5}
.q-cross{margin-bottom:18px;filter:drop-shadow(0 0 14px rgba(224,0,154,.65));animation:cpulse 3.5s ease-in-out infinite}
.q-mark-open{font-family:var(--font-display);font-size:7rem;font-weight:600;line-height:.7;color:rgba(255,120,190,.78);margin-bottom:-18px;align-self:flex-start;margin-left:16px;text-shadow:0 0 30px rgba(224,0,154,.3);user-select:none}
.q-mark-close{font-family:var(--font-display);font-size:7rem;font-weight:600;line-height:.5;color:rgba(255,120,190,.78);margin-top:-8px;align-self:flex-end;margin-right:16px;text-shadow:0 0 30px rgba(224,0,154,.3);user-select:none}
/* FIX: reset blockquote browser indent */
.q-blockquote{font-family:var(--font-display);font-size:clamp(1.2rem,2.4vw,1.7rem);font-style:italic;font-weight:300;color:var(--mg5);line-height:1.65;letter-spacing:.02em;max-width:600px;text-shadow:0 0 40px rgba(224,0,154,.18);margin:0;padding:0;border:none}
.q-divider{display:flex;align-items:center;gap:12px;margin:20px 0 14px;width:100%;justify-content:center}
.q-div-line{width:70px;height:1px;background:linear-gradient(90deg,transparent,rgba(224,0,154,.45))}
.q-div-r{background:linear-gradient(270deg,transparent,rgba(224,0,154,.45))}
.q-attr{font-family:var(--font-heading);font-size:.48rem;letter-spacing:.32em;text-transform:uppercase;color:var(--gold);opacity:.72}
.q-bottom-lead{height:4px;background:linear-gradient(90deg,transparent,var(--gold) 15%,var(--mg) 35%,var(--mg2) 50%,var(--mg) 65%,var(--gold) 85%,transparent)}

/* ══ ABOUT ══ */
/* FIX: padding was missing from about-content */
.about-content{background:var(--dark3)}
.about-mg{display:grid;grid-template-columns:1fr 520px;min-height:580px;position:relative;overflow:hidden}
.about-mg-l{padding:72px 56px;display:flex;flex-direction:column;justify-content:center;gap:18px;position:relative;z-index:5}
.about-mg-l::after{content:'';position:absolute;right:0;top:10%;bottom:10%;width:1px;background:linear-gradient(180deg,transparent,rgba(255,100,180,.68),rgba(240,200,74,.3),transparent)}
.about-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(224,0,154,.1);border:1px solid rgba(224,0,154,.3);padding:5px 14px;align-self:flex-start}
.about-bdot{width:5px;height:5px;border-radius:50%;background:var(--mg2);animation:bdot2 1.8s ease-in-out infinite}
@keyframes bdot2{0%,100%{opacity:1;box-shadow:0 0 6px rgba(255,0,200,.8)}50%{opacity:.3;box-shadow:none}}
.about-btxt{font-family:var(--font-heading);font-size:.4rem;letter-spacing:.2em;text-transform:uppercase;color:var(--mg3)}
.about-mg-title{font-family:var(--font-display);font-size:2.6rem;font-weight:300;font-style:italic;color:var(--mg5);line-height:1.08}
.about-mg-title span{display:block;font-size:1.5rem;background:linear-gradient(90deg,var(--mg4),var(--gold2),var(--mg3));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-top:2px}
.about-mg-text{font-style:italic;font-size:.93rem;color:rgba(255,180,220,.88);line-height:1.9;max-width:460px}
.about-stats{display:flex;gap:28px;padding-top:18px;border-top:1px solid rgba(224,0,154,.12)}
.ast2{display:flex;flex-direction:column;gap:3px}
.astn{font-family:var(--font-display);font-size:1.85rem;font-weight:300;font-style:italic;color:var(--mg2);line-height:1}
.astl{font-family:var(--font-heading);font-size:.44rem;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,120,190,.78)}
.about-btn2{font-family:var(--font-heading);font-size:.48rem;letter-spacing:.2em;text-transform:uppercase;color:var(--mg3);border:1px solid rgba(255,100,180,.65);padding:11px 24px;cursor:pointer;align-self:flex-start;transition:all .3s;position:relative;overflow:hidden;text-decoration:none;display:inline-block}
.about-btn2::before{content:'';position:absolute;inset:0;background:rgba(224,0,154,.22);transform:scaleX(0);transform-origin:left;transition:transform .3s cubic-bezier(.77,0,.175,1)}
.about-btn2:hover::before{transform:scaleX(1)}
.about-btn2 span{position:relative;z-index:1}
.about-mg-r{position:relative;overflow:hidden;background:linear-gradient(145deg,var(--dark4),var(--dark3));display:flex;align-items:center;justify-content:center}
.about-mg-r::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 40%,rgba(224,0,154,.22) 0%,transparent 65%),radial-gradient(ellipse at 80% 80%,rgba(144,0,200,.14) 0%,transparent 50%)}
.about-rose-bg{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);opacity:.09;pointer-events:none;animation:rbreath 7s ease-in-out infinite}
.about-wand-glow{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:280px;height:280px;border-radius:50%;background:radial-gradient(circle,rgba(224,0,154,.32) 0%,rgba(144,0,200,.18) 40%,transparent 70%);pointer-events:none;animation:wglw 3.5s ease-in-out infinite}
.about-wand-glow2{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:160px;height:160px;border-radius:50%;background:radial-gradient(circle,rgba(255,100,200,.28) 0%,transparent 65%);pointer-events:none;animation:wglw 2.5s ease-in-out infinite .8s}
@keyframes wglw{0%,100%{opacity:.5;transform:translate(-50%,-50%) scale(1)}40%{opacity:1;transform:translate(-50%,-50%) scale(1.3)}70%{opacity:.8;transform:translate(-50%,-50%) scale(1.15)}}
.about-wand-c{position:relative;z-index:5;display:flex;flex-direction:column;align-items:center;animation:wcfloat 5s ease-in-out infinite;filter:drop-shadow(0 0 18px rgba(224,0,154,.6)) drop-shadow(0 0 40px rgba(224,0,154,.25))}
@keyframes wcfloat{0%,100%{transform:translateY(0) rotate(-6deg)}25%{transform:translateY(-8px) rotate(-2deg)}50%{transform:translateY(-18px) rotate(6deg)}75%{transform:translateY(-6px) rotate(2deg)}}
/* FIX: orbit-wrap — position:absolute, centered with top/left 50%, width/height 0 so gems orbit from center */
.orbit-wrap{position:absolute;top:50%;left:50%;width:0;height:0;z-index:6;pointer-events:none}
.orbit-gem{position:absolute;animation:orb var(--od,4s) linear infinite var(--odl,0s);pointer-events:none;filter:drop-shadow(0 0 6px var(--gc,rgba(224,0,154,.8)))}
@keyframes orb{from{transform:rotate(0deg) translateX(var(--r,80px)) rotate(0deg)}to{transform:rotate(360deg) translateX(var(--r,80px)) rotate(-360deg)}}
.wand-spark{position:absolute;border-radius:50%;animation:wspk var(--d,1.2s) ease-in-out infinite var(--dl,0s);pointer-events:none}
@keyframes wspk{0%{opacity:0;transform:translate(0,0) scale(0)}35%{opacity:1;transform:translate(var(--tx,4px),var(--ty,-8px)) scale(1.2)}100%{opacity:0;transform:translate(var(--tx2,8px),var(--ty2,-18px)) scale(.1)}}
.about-corner-tl{position:absolute;top:14px;right:14px;width:24px;height:24px;border-top:1.5px solid rgba(240,200,74,.4);border-right:1.5px solid rgba(240,200,74,.4);z-index:6;pointer-events:none}
.about-corner-tr{position:absolute;top:14px;left:14px;width:24px;height:24px;border-top:1.5px solid rgba(240,200,74,.4);border-left:1.5px solid rgba(240,200,74,.4);z-index:6;pointer-events:none}

/* ══ MAGICAL GIRL PHONE ══ */
.cp-wrap{
  position:relative;z-index:5;
  display:flex;align-items:center;justify-content:center;
  animation:phone-float 5.5s ease-in-out infinite;
  filter:
    drop-shadow(0 0 20px rgba(232,0,106,.72))
    drop-shadow(0 0 48px rgba(232,0,106,.32))
    drop-shadow(0 12px 28px rgba(0,0,0,.45));
}
@keyframes phone-float{
  0%,100%{transform:translateY(0) rotate(-4deg);}
  25%{transform:translateY(-12px) rotate(-2deg);}
  55%{transform:translateY(-20px) rotate(4deg);}
  80%{transform:translateY(-8px) rotate(2deg);}
}
.cp-svg{width:min(240px,75%);height:auto;}

/* Glow halos */
.cp-glow-outer{
  position:absolute;width:360px;height:420px;border-radius:50%;
  background:radial-gradient(ellipse,rgba(232,0,106,.18) 0%,rgba(160,0,180,.1) 45%,transparent 70%);
  animation:cp-pulse-out 4.5s ease-in-out infinite;pointer-events:none;
}
.cp-glow-inner{
  position:absolute;width:220px;height:260px;border-radius:50%;
  background:radial-gradient(ellipse,rgba(255,100,190,.28) 0%,rgba(232,0,106,.1) 55%,transparent 75%);
  animation:cp-pulse-in 3s ease-in-out infinite .6s;pointer-events:none;
}
@keyframes cp-pulse-out{0%,100%{opacity:.45;transform:scale(1);}50%{opacity:.85;transform:scale(1.08);}}
@keyframes cp-pulse-in{0%,100%{opacity:.55;transform:scale(1);}50%{opacity:1;transform:scale(1.18);}}

/* Floating sparkles */
.cp-sparks{position:absolute;inset:0;pointer-events:none;}
.cp-spark{
  position:absolute;top:50%;left:50%;
  width:6px;height:6px;border-radius:50%;
  background:rgba(255,220,240,1);
  animation:cp-sparkle var(--d,2s) ease-out infinite var(--dl,0s);
  transform:translate(calc(var(--x) - 3px), calc(var(--y) - 3px));
  box-shadow:0 0 7px rgba(232,0,106,.95);
}
.cp-spark-star{
  width:9px;height:9px;border-radius:0;background:rgba(240,200,74,.95);
  clip-path:polygon(50% 0%,58% 38%,100% 50%,58% 62%,50% 100%,42% 62%,0% 50%,42% 38%);
}
@keyframes cp-sparkle{
  0%  {opacity:0;transform:translate(calc(var(--x) - 3px),calc(var(--y) - 3px)) scale(0) rotate(0deg);}
  35% {opacity:1;transform:translate(calc(var(--x) - 3px),calc(var(--y) - 3px)) scale(1.6) rotate(60deg);}
  100%{opacity:0;transform:translate(calc(var(--x) + 6px),calc(var(--y) - 18px)) scale(0) rotate(180deg);}
}

/* Screen blink animation */
.ph-blink{animation:ph-blink 1.2s step-end infinite;}
@keyframes ph-blink{0%,100%{opacity:1;}50%{opacity:0;}}
/* Antenna tip pulse */
.ph-ant-pulse{animation:ph-ant-pulse 2s ease-in-out infinite;}
@keyframes ph-ant-pulse{0%,100%{opacity:.2;transform:scale(1);}50%{opacity:.55;transform:scale(1.4);}}

/* Light mode */
body.light .cp-wrap{
  filter:drop-shadow(0 0 16px rgba(232,0,106,.45)) drop-shadow(0 0 36px rgba(232,0,106,.2)) drop-shadow(0 8px 20px rgba(0,0,0,.25));
}
body.light .cp-glow-outer{background:radial-gradient(ellipse,rgba(232,0,106,.1) 0%,transparent 68%);}
body.light .cp-glow-inner{background:radial-gradient(ellipse,rgba(255,100,190,.15) 0%,transparent 70%);}

/* ══ WAND DIVIDER ══ */
.wand-div-content {
  padding: 90px 0;
  background:
    radial-gradient(ellipse 60% 80% at 50% 50%, rgba(100,0,80,.22) 0%, transparent 65%),
    linear-gradient(180deg, var(--dark3) 0%, var(--dark2) 50%, var(--dark3) 100%);
  position: relative; overflow: hidden;
  min-height: 680px;
  display: flex; align-items: center;
}
/* Subtle grain overlay */
.wand-div-content::after {
  content: ''; position: absolute; inset: 0; pointer-events: none; z-index: 1;
  background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(232,0,106,.012) 2px, rgba(232,0,106,.012) 4px);
}

/* Top/bottom horizontal lead borders */
.wd-lead-h {
  position: absolute; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, transparent 0%, rgba(240,200,74,.4) 12%, rgba(232,0,106,.6) 30%, var(--mg) 50%, rgba(232,0,106,.6) 70%, rgba(240,200,74,.4) 88%, transparent 100%);
  z-index: 10; pointer-events: none;
}
.wd-lead-top { top: 0; }
.wd-lead-bot { bottom: 0; }

/* Gothic arch backgrounds — positioned at edges */
.wd-bg-arches { position: absolute; inset: 0; pointer-events: none; z-index: 2; display: flex; justify-content: space-between; align-items: stretch; }
.wd-arch-l { width: 22%; height: 100%; flex-shrink: 0; }
.wd-arch-r { width: 22%; height: 100%; flex-shrink: 0; }

/* Three-column layout */
.wd-layout {
  display: grid;
  grid-template-columns: 1fr 240px 1fr;
  align-items: center;
  gap: 28px;
  position: relative; z-index: 5;
  width: 100%;
  padding: 0 60px;
}

/* Left column */
.wd-col-left {
  display: flex; flex-direction: column; align-items: flex-end;
  gap: 22px; text-align: right;
}
.wd-eyebrow {
  font-family: var(--font-heading); font-size: .48rem; letter-spacing: .42em;
  text-transform: uppercase; color: var(--gold);
  display: flex; align-items: center; gap: 10px;
}
.wd-eye-line { height: 1px; width: 28px; background: linear-gradient(90deg, transparent, var(--gold)); }
.wd-eye-r    { background: linear-gradient(270deg, transparent, var(--gold)); }
.wd-cross-orn { filter: drop-shadow(0 0 8px rgba(232,0,106,.4)); }
.wd-quote-left {
  font-family: var(--font-display); font-size: clamp(1.05rem, 1.7vw, 1.45rem);
  font-weight: 300; color: var(--mg5); line-height: 1.68;
  text-shadow: 0 0 20px rgba(232,0,106,.15);
}
.wd-quote-left em { color: var(--mg3); font-style: italic; }

/* Poem block left */
.wd-poem { display: flex; flex-direction: column; align-items: flex-end; gap: 6px; }
.wd-poem-line {
  font-family: var(--font-heading); font-size: .46rem; letter-spacing: .28em;
  text-transform: uppercase; color: var(--mg4);
}
.wd-poem-divider {
  display: flex; align-items: center; gap: 8px;
}
.wd-poem-div-line { width: 32px; height: 1px; background: linear-gradient(90deg, transparent, rgba(232,0,106,.42)); }

/* Right column */
.wd-col-right {
  display: flex; flex-direction: column; align-items: flex-start;
  gap: 22px;
}
.wd-quote-right {
  font-family: var(--font-display); font-size: clamp(1.05rem, 1.7vw, 1.45rem);
  font-weight: 300; font-style: italic; color: var(--mg5); line-height: 1.68;
  text-shadow: 0 0 20px rgba(232,0,106,.15);
}
.wd-quote-right em { color: var(--mg3); }
.wd-stats { display: flex; flex-direction: column; gap: 0; }
.wd-stat { padding: 12px 0; }
.wd-stat-n {
  font-family: var(--font-display); font-size: 1.85rem;
  font-weight: 300; font-style: italic; color: var(--mg2);
  line-height: 1; filter: drop-shadow(0 0 10px rgba(232,0,106,.55));
}
.wd-stat-l {
  font-family: var(--font-heading); font-size: .44rem;
  letter-spacing: .2em; text-transform: uppercase;
  color: var(--mg4); margin-top: 4px;
}
.wd-stat-divider {
  height: 1px;
  background: linear-gradient(90deg, rgba(232,0,106,.32), rgba(240,200,74,.2), transparent);
}

/* Center: wand + orbits + glows */
.wd-center {
  position: relative;
  display: flex; align-items: center; justify-content: center;
  height: 620px;
}

/* ── WAND GLOWS — layered, breathing, magical ── */
.wd-glow-outer {
  position: absolute; width: 500px; height: 500px; border-radius: 50%;
  background: radial-gradient(circle,
    rgba(232,0,106,.22) 0%,
    rgba(160,0,200,.14) 35%,
    rgba(232,0,106,.06) 60%,
    transparent 75%);
  animation: wd-pulse-outer 5s ease-in-out infinite;
  pointer-events: none;
}
.wd-glow-inner {
  position: absolute; width: 300px; height: 300px; border-radius: 50%;
  background: radial-gradient(circle,
    rgba(255,80,180,.35) 0%,
    rgba(232,0,106,.18) 40%,
    transparent 70%);
  animation: wd-pulse-inner 3.2s ease-in-out infinite .4s;
  pointer-events: none;
}
.wd-glow-pulse {
  position: absolute; width: 160px; height: 160px; border-radius: 50%;
  background: radial-gradient(circle, rgba(255,200,240,.55) 0%, rgba(255,100,190,.2) 50%, transparent 75%);
  animation: wd-pulse-core 1.8s ease-in-out infinite .8s;
  pointer-events: none;
}

/* spinning border rings removed */

@keyframes wd-pulse-outer {
  0%,100% { opacity: .45; transform: scale(1); }
  33%     { opacity: .85; transform: scale(1.08); }
  66%     { opacity: .55; transform: scale(1.04); }
}
@keyframes wd-pulse-inner {
  0%,100% { opacity: .6;  transform: scale(1); }
  50%     { opacity: 1;   transform: scale(1.18); }
}
@keyframes wd-pulse-core {
  0%,100% { opacity: .5;  transform: scale(.9); }
  50%     { opacity: 1;   transform: scale(1.3); }
}


/* Stardust particles — tiny dots scattered around wand */
.wd-stardust { position: absolute; inset: 0; pointer-events: none; overflow: visible; }

/* Orbiting gems */
.wd-orbits { position: absolute; inset: 0; pointer-events: none; }
.wd-orbit-gem {
  position: absolute;
  top: 50%; left: 50%;
  animation: wd-orb var(--od,5s) linear infinite var(--odl,0s);
  filter: drop-shadow(0 0 7px var(--gc, rgba(232,0,106,.9)));
}
@keyframes wd-orb {
  from { transform: rotate(0deg) translateX(var(--or,100px)) rotate(0deg); }
  to   { transform: rotate(360deg) translateX(var(--or,100px)) rotate(-360deg); }
}

/* Wand wrap — bigger, more dramatic float */
.wd-wand-wrap {
  position: relative; z-index: 5;
  animation: wd-float 6s ease-in-out infinite;
  filter:
    drop-shadow(0 0 18px rgba(232,0,106,.9))
    drop-shadow(0 0 40px rgba(232,0,106,.55))
    drop-shadow(0 0 80px rgba(232,0,106,.22))
    drop-shadow(0 0 120px rgba(200,0,160,.12));
}
@keyframes wd-float {
  0%   { transform: translateY(0px)    rotate(-6deg) scale(1); }
  20%  { transform: translateY(-12px)  rotate(-3deg) scale(1.01); }
  50%  { transform: translateY(-24px)  rotate(6deg)  scale(1.02); }
  80%  { transform: translateY(-10px)  rotate(3deg)  scale(1.01); }
  100% { transform: translateY(0px)    rotate(-6deg) scale(1); }
}

/* Heart shimmer — separate animation on the magenta fill */
@keyframes heart-shimmer {
  0%,100% { filter: brightness(1) drop-shadow(0 0 4px rgba(255,100,180,.5)); }
  50%     { filter: brightness(1.3) drop-shadow(0 0 14px rgba(255,160,210,.9)); }
}

.wd-wand-svg { width: 220px; height: auto; }
/* Heart path gets shimmer via animation on svg */
.wd-wand-svg { animation: wd-float 6s ease-in-out infinite, heart-shimmer 2.5s ease-in-out infinite; }

/* Spark keyframe — bigger travel distance */
@keyframes wspk-big {
  0%   { opacity:0; transform:translate(0,0) scale(0) rotate(0deg); }
  25%  { opacity:1; transform:translate(calc(var(--tx)*.5),calc(var(--ty)*.5)) scale(1.4) rotate(45deg); }
  100% { opacity:0; transform:translate(var(--tx2),var(--ty2)) scale(0) rotate(180deg); }
}
.wand-spark {
  position: absolute; border-radius: 50%;
  animation: wspk-big var(--d,1.5s) ease-out infinite var(--dl,0s);
  pointer-events: none;
}

/* energy rings removed */

/* Light mode */
body.light .wand-div-content { background: linear-gradient(145deg, #f0e6f8, #f8eeff); }
body.light .wd-quote-left    { color: #1a0828; }
body.light .wd-stat-n        { color: var(--mg); filter: none; }
body.light .wd-stat-l        { color: rgba(100,0,80,.7); }
body.light .wd-stat-divider  { background: linear-gradient(90deg, rgba(220,0,100,.25), transparent); }

