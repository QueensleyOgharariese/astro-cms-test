            <div class="pm-top-bar" aria-hidden="true"></div>
            <div class="pm-body">
              <div class="pm-cat">{catLabel(post.data.category)}</div>
              <div class="pm-title">{post.data.title}</div>
              <div class="pm-meta">{formatDate(post.data.pubDate)}{ratingStr(post.data.rating)}</div>
