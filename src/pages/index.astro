                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="pm-corner-tl" aria-hidden="true"></div>
            <div class="pm-corner-br" aria-hidden="true"></div>
            <div class="pm-shine"     aria-hidden="true"></div>
          </a>
        ))}
      </div>
    )}

    <!-- Only show "view all" button when there are posts -->
    {allPosts.length > 0 && (
      <div class="feat-view-all">
        <a class="btn-lead" href="/blog"><span>View all posts →</span></a>
      </div>
    )}
  </div>
</section>


