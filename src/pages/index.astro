---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sorted   = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featured = sorted[0];        // undefined when no posts — guarded in template
const recent   = sorted.slice(1, 7);

// Fallback label so unknown categories never render "undefined"
const catLabels: Record<string, string> = {
  manhwa: 'Manhwa', manga: 'Manga', anime: 'Anime', style: 'Style'
};
function catLabel(cat: string): string { return catLabels[cat] ?? cat; }

// Explicit null-check — rating 0 is falsy, so `&&` would skip it
function ratingStr(r: number | undefined): string { return r != null ? ` · ${r}/10` : ''; }

function formatDate(d: Date): string {
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}

const catList = [
  { slug: 'manhwa', label: 'Manhwa',      count: allPosts.filter(p => p.data.category === 'manhwa').length },
  { slug: 'manga',  label: 'Manga',       count: allPosts.filter(p => p.data.category === 'manga').length  },
  { slug: 'anime',  label: 'Anime',       count: allPosts.filter(p => p.data.category === 'anime').length  },
  { slug: 'style',  label: 'Style',       count: allPosts.filter(p => p.data.category === 'style').length  },
  { slug: 'games',  label: 'Video Games', count: allPosts.filter(p => p.data.category === 'games').length  },
];
---

