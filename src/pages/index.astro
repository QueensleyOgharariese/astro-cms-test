<div class="sg-strip"><div class="sg-strip-t" id="sgstrip"></div></div>
<div class="mq"><div class="mt" id="mtrack"></div></div>

<!-- ══ FEATURED + BLOG GRID ══ -->
<div class="section-lead"></div>
<section id="featured" class="glass-section">
  <div class="panel-content feat-content">

    <div class="sec-head">
      <div class="sec-over"><div class="sec-rule"></div>latest posts<div class="sec-rule"></div></div>
      <div class="sec-title">From the blog</div>
    </div>

    {featured ? (
      <a class="big-panel" href={`/posts/${featured.slug}`}>
        <div class="bp-vis">
          <div class="bp-vis-bg"></div>
          <div class="bp-glow"></div>
          <div class="bp-glass" aria-hidden="true">
