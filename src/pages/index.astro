<script>
/* Guard both elements — null crashes the whole page otherwise */
function buildMagicTitle(): void {
  const lEl = document.getElementById('title-little');
  const cEl = document.getElementById('title-conf');
  if (!lEl || !cEl) return;

  'Little'.split('').forEach((ch, i) => {
    const s = document.createElement('span');
    s.className = 'magic-letter';
    s.textContent = ch === ' ' ? '\u00A0' : ch;
    s.style.animationDelay = `${0.08 + i * 0.09}s`;
    lEl.appendChild(s);
  });

  'Confidants'.split('').forEach((ch, i) => {
    const s = document.createElement('span');
    s.className = 'magic-letter';
    s.textContent = ch === ' ' ? '\u00A0' : ch;
    s.style.animationDelay = `${0.72 + i * 0.08}s`;
    cEl.appendChild(s);
  });
}
buildMagicTitle();

/* Null-safe quote strip — runs only on this page */
(function buildQuoteStrip(): void {
  const el = document.getElementById('q-strip');
  if (!el) return;
  const colors = [
    'rgba(224,0,154,.52)',
    'rgba(240,200,74,.48)',
    'rgba(144,0,200,.42)',
    'rgba(0,200,212,.36)',
    'rgba(224,0,154,.58)',
  ];
  const w    = Math.max(window.innerWidth, 1200);
  const cols = Math.ceil(w / 16) + 2;
  let svg = `<svg width="${w}" height="28" viewBox="0 0 ${w} 28" fill="none" style="display:block">`;
  for (let i = 0; i < cols; i++) {
    const x = i * 16;
    svg += `<polygon points="${x+8},0 ${x+16},14 ${x+8},28 ${x},14" fill="${colors[i % colors.length]}" stroke="rgba(14,8,32,1)" stroke-width="1.5"/>`;
  }
  svg += '</svg>';
  el.innerHTML = svg;
})();
</script>