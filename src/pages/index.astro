              <rect x="3"   y="3"   width="214" height="294" stroke="rgba(240,200,74,.68)" stroke-width="2.5" fill="none"/>
              <rect x="8"   y="8"   width="204" height="284" stroke="rgba(224,0,154,.28)"  stroke-width=".8"  fill="none"/>
              <path d="M3 115 Q110 3 217 115" fill="rgba(224,0,154,.11)" stroke="rgba(240,200,74,.68)" stroke-width="2"/>
              <circle cx="110" cy="72"  r="26" fill="rgba(224,0,154,.22)" stroke="rgba(240,200,74,.58)" stroke-width="1.5"/>
              <circle cx="74"  cy="96"  r="21" fill="rgba(144,0,200,.18)" stroke="rgba(240,200,74,.42)" stroke-width="1.2"/>
              <circle cx="146" cy="96"  r="21" fill="rgba(224,0,154,.2)"  stroke="rgba(240,200,74,.42)" stroke-width="1.2"/>
              <circle cx="110" cy="72"  r="11" fill="rgba(255,128,216,.28)"/>
              <polygon points="110,122 155,165 110,208 65,165" fill="rgba(224,0,154,.2)"  stroke="rgba(240,200,74,.58)" stroke-width="1.8"/>
              <rect x="10"  y="120" width="48" height="82" fill="rgba(224,0,154,.1)"  stroke="rgba(240,200,74,.38)" stroke-width="1.2"/>
              <rect x="162" y="120" width="48" height="82" fill="rgba(144,0,200,.1)"  stroke="rgba(240,200,74,.38)" stroke-width="1.2"/>
              <rect x="10"  y="212" width="60" height="78" fill="rgba(240,200,74,.07)" stroke="rgba(240,200,74,.38)" stroke-width="1.2"/>
              <rect x="80"  y="212" width="60" height="78" fill="rgba(224,0,154,.1)"  stroke="rgba(240,200,74,.38)" stroke-width="1.2"/>
              <rect x="150" y="212" width="60" height="78" fill="rgba(0,200,212,.07)"  stroke="rgba(240,200,74,.38)" stroke-width="1.2"/>
              <line x1="110" y1="120" x2="110" y2="290" stroke="rgba(240,200,74,.38)" stroke-width="1.5"/>
              <line x1="10"  y1="210" x2="210" y2="210" stroke="rgba(240,200,74,.32)" stroke-width="1.2"/>
            </svg>
          </div>
          <!-- Gold corner brackets via position:absolute children (not ::before/::after which fight bp-vis-bg) -->
          <div class="bp-corner-tl" aria-hidden="true"></div>
          <div class="bp-corner-br" aria-hidden="true"></div>
          <div class="bp-badge">✦ Latest</div>
        </div>

        <div class="bp-divider" aria-hidden="true"></div>

        <div class="bp-body">
          <div class="bp-cat">
            {catLabel(featured.data.category)}
            {featured.data.spoilers && <span class="bp-spoiler">⚠ Spoilers</span>}
          </div>
          <div class="bp-title">{featured.data.title}</div>
          <div class="bp-desc">{featured.data.description}</div>
          <!-- ratingStr() handles 0, undefined, null correctly -->
          <div class="bp-meta">{formatDate(featured.data.pubDate)}{ratingStr(featured.data.rating)}</div>
          {featured.data.tags.length > 0 && (
            <div class="bp-tags">
              {featured.data.tags.slice(0, 4).map(t => <span class="bp-tag">#{t}</span>)}
            </div>
