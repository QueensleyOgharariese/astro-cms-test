    <!-- Mosaic grid — rectangles + squares via grid-auto-rows -->
    {recent.length > 0 && (
      <div class="post-mosaic">
        {recent.map((post, i) => (
          <a
            class={`pm-card pm-card-${(i % 6) + 1}`}
            href={`/posts/${post.slug}`}
