<style>
/* ══ HERO ══ */
#recs-hero{
  min-height:62vh;position:relative;overflow:hidden;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:90px 52px 60px;
  background:linear-gradient(180deg,var(--dark) 0%,var(--dark2) 60%,var(--dark) 100%);
}
.rh-bg{position:absolute;inset:0;background:radial-gradient(ellipse 55% 55% at 50% 42%,rgba(232,0,106,.2) 0%,transparent 60%),radial-gradient(ellipse 30% 35% at 18% 18%,rgba(140,0,180,.1) 0%,transparent 55%),radial-gradient(ellipse 28% 32% at 82% 18%,rgba(240,200,74,.07) 0%,transparent 55%)}
.rh-vignette{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%,transparent 28%,rgba(0,0,0,.72) 100%);z-index:1}
.rh-rose{position:absolute;z-index:2;top:50%;left:50%;transform:translate(-50%,-50%);width:min(72vmin,500px);height:min(72vmin,500px);pointer-events:none;animation:rbreath 6s ease-in-out infinite}
@keyframes rbreath{0%,100%{opacity:.2}50%{opacity:.32}}
.rh-arches{position:absolute;z-index:3;top:50%;left:50%;transform:translate(-50%,-50%);width:min(85vw,560px);height:auto;pointer-events:none}
.rh-lh{position:absolute;left:0;right:0;height:2px;z-index:4;pointer-events:none;background:linear-gradient(90deg,transparent,rgba(240,200,74,.28),rgba(232,0,106,.42),rgba(240,200,74,.28),transparent)}
.rh-inner{position:relative;z-index:10;text-align:center;display:flex;flex-direction:column;align-items:center;gap:0}
.rh-ornament{margin-bottom:18px;filter:drop-shadow(0 0 12px rgba(232,0,106,.58));animation:cpulse 3.5s ease-in-out infinite}
@keyframes cpulse{0%,100%{filter:drop-shadow(0 0 12px rgba(232,0,106,.5))}50%{filter:drop-shadow(0 0 28px rgba(255,68,153,.85))}}
.rh-eyebrow{font-family:var(--font-heading);font-size:.46rem;letter-spacing:.52em;text-transform:uppercase;color:var(--gold);margin-bottom:14px;display:flex;align-items:center;gap:12px;opacity:0;animation:fadeup .7s ease .1s forwards}
.rhe-l{height:1px;width:38px;background:linear-gradient(90deg,transparent,var(--gold))}
.rhe-r{height:1px;width:38px;background:linear-gradient(270deg,transparent,var(--gold))}
@keyframes fadeup{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
.rh-title{font-family:var(--font-display);font-size:clamp(2.8rem,7vw,5.5rem);font-weight:300;font-style:italic;line-height:.92;margin-bottom:12px;background:linear-gradient(135deg,var(--mg5) 0%,var(--mg4) 25%,var(--mg3) 48%,var(--gold2) 65%,var(--mg3) 80%,var(--mg5) 100%);background-size:280% 280%;-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:shimmer-t 5s ease-in-out infinite,fadeup .9s ease .05s both}
@keyframes shimmer-t{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
.rh-sub{font-family:var(--font-display);font-style:italic;font-size:1rem;color:rgba(255,160,225,.48);letter-spacing:.08em;margin-bottom:28px;opacity:0;animation:fadeup .8s ease .3s forwards}
.rh-cats{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;opacity:0;animation:fadeup .8s ease .5s forwards}
.rh-cat{font-family:var(--font-heading);font-size:.44rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,240,248,.55);padding:9px 20px;text-decoration:none;border:1px solid rgba(232,0,106,.28);transition:all .22s;background:rgba(232,0,106,.06)}
.rh-cat:hover,.rh-cat:focus{color:var(--mg4);border-color:rgba(232,0,106,.65);background:rgba(232,0,106,.14)}
.rh-cat-1{border-color:rgba(240,200,74,.3);color:var(--gold);background:rgba(240,200,74,.06)}
