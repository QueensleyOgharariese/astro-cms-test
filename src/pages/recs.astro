---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allRecs = await getCollection('recs');
const sorted  = allRecs.sort((a,b) => b.data.rating - a.data.rating);
const mustRead = sorted.filter(r => r.data.mustRead);
const others   = sorted.filter(r => !r.data.mustRead);

// Sample data so page is never empty
const sampleMust = [
  { title:'The Remarried Empress', creator:'Alphatart', type:'manhwa', rating:9.5, status:'completed', mustRead:true,
    description:'A queen who refuses to be a victim. Political intrigue, gorgeous art, and an empress who is absolutely iconic.',
    tags:['royalty','strong-heroine','political','must-read'] },
  { title:'A Fake Soulmate but a Real Marriage', creator:'Narak', type:'manhwa', rating:9.2, status:'ongoing', mustRead:true,
    description:'Enemies-to-lovers done so right it physically hurts. The tension is immaculate.',
    tags:['romance','enemies-to-lovers','slowburn'] },
];
const samplePicks = [
  { title:'Frieren: Beyond Journey\'s End', creator:'Kanehito Yamada', type:'manga', rating:9.8, status:'ongoing',
    description:'Grief, time and what it means to live slowly. The quietest manga that hits the hardest.',
    tags:['fantasy','emotional','must-read'] },
  { title:'I Became the Tyrant\'s Secretary', creator:'Mira', type:'manhwa', rating:8.8, status:'completed',
    description:'The most chaotic office romance imaginable. Incredibly fun from start to finish.',
    tags:['romance','comedy','historical'] },
  { title:'Dungeon Meshi', creator:'Ryoko Kui', type:'manga', rating:9.6, status:'completed',
    description:'A cooking + dungeon-crawling manga that becomes something profound. One of a kind.',
    tags:['fantasy','cozy','adventure'] },
  { title:'I Am the Villain', creator:'Siya', type:'manhwa', rating:8.5, status:'ongoing',
    description:'The villainess trope at its absolute peak. Dark, clever, and surprisingly tender.',
    tags:['villainess','fantasy','dark'] },
  { title:'A Sign of Affection', creator:'Suu Morishita', type:'manga', rating:9.0, status:'completed',
    description:'The softest, most sincere romance manga I\'ve read. It made me want to be kinder.',
    tags:['romance','slice-of-life','wholesome'] },
  { title:'Dark Coquette Aesthetics', creator:'Various', type:'style', rating:8.2, status:undefined,
    description:'Gothic lolita meets dark feminine energy — the aesthetic moodboard I live in my head.',
    tags:['fashion','dark','aesthetic'] },
];

const showMust  = mustRead.length  > 0 ? mustRead.map(r  => ({...r.data, slug: r.slug})) : sampleMust;
const showPicks = others.length    > 0 ? others.map(r   => ({...r.data, slug: r.slug})) : samplePicks;

const typeColor:  Record<string,string> = { manhwa:'var(--mg)', manga:'var(--gold)', style:'var(--t)', music:'var(--v2)' };
const typeLabel:  Record<string,string> = { manhwa:'Manhwa', manga:'Manga', style:'Style', music:'Music' };
const statusLabel:Record<string,string> = { completed:'Complete', ongoing:'Ongoing', hiatus:'On Hiatus' };

function stars(r:number){ return '★'.repeat(Math.round(r/2))+'☆'.repeat(5-Math.round(r/2)); }
---

