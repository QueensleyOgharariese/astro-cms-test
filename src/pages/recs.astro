.rh-lead-bot{position:absolute;bottom:0;left:0;right:0;height:4px;background:linear-gradient(90deg,transparent,var(--gold) 15%,var(--mg) 35%,var(--mg2) 50%,var(--mg) 65%,var(--gold) 85%,transparent)}

/* ══ FLOATING DECO ══ */
.fd-left,.fd-right{position:fixed;top:50%;z-index:4;pointer-events:none;transform:translateY(-50%)}
.fd-left{left:clamp(4px,1.5vw,20px);animation:fd-float 5.5s ease-in-out infinite;filter:drop-shadow(0 0 12px rgba(232,0,106,.58)) drop-shadow(0 0 28px rgba(232,0,106,.22))}
.fd-right{right:clamp(4px,1.5vw,20px);animation:fd-float 6s ease-in-out infinite .5s;filter:drop-shadow(0 0 10px rgba(232,0,106,.5)) drop-shadow(0 0 24px rgba(232,0,106,.18))}
@keyframes fd-float{0%,100%{transform:translateY(-50%) rotate(-3deg)}50%{transform:translateY(calc(-50% - 14px)) rotate(3deg)}}
.fd-sym{position:absolute;font-family:var(--font-display);font-size:.9rem;color:var(--mg3);opacity:0;animation:fd-sym var(--d,2s) ease-out infinite var(--dl,0s);left:var(--x,0);top:var(--y,0);pointer-events:none}
@keyframes fd-sym{0%{opacity:0;transform:scale(0)}35%{opacity:.9;transform:scale(1.2)}100%{opacity:0;transform:scale(.1) translateY(-14px)}}
.rc-spark{border-radius:50%;animation:wspk var(--d,1.5s) ease-out infinite var(--dl,0s)}
@keyframes wspk{0%{opacity:0;transform:translate(0,0) scale(0)}35%{opacity:1;transform:translate(var(--tx,4px),var(--ty,-8px)) scale(1.2)}100%{opacity:0;transform:translate(var(--tx2,8px),var(--ty2,-18px)) scale(.1)}}

/* ══ SECTION INNER ══ */
