---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const all  = await getCollection('posts', ({ data }) => !data.draft);
const posts = all.sort((a,b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featured = posts[0];
const rest     = posts.slice(1);

const sample = [
  { title:'The Remarried Empress — A Queen Who Refuses to Fall', cat:'manhwa', date:'10 Mar 2025', rating:'9.5', tags:['royalty','strong-heroine'], size:'large' },
  { title:'Frieren: Beyond Journey\'s End Is Everything',         cat:'anime',  date:'8 Mar 2025',  rating:'10',  tags:['fantasy','emotional'],      size:'small' },
  { title:'5 Games to Play If You Love Dark Atmospheres',         cat:'games',  date:'5 Mar 2025',  rating:null,  tags:['recs','dark'],              size:'small' },
  { title:'Why Isekai Manhwa Heroines Hit Different in 2025',     cat:'manhwa', date:'2 Mar 2025',  rating:null,  tags:['discussion'],               size:'wide'  },
  { title:'Dungeon Meshi — A Love Letter to Slow Food',           cat:'anime',  date:'28 Feb 2025', rating:'9',   tags:['cozy','fantasy'],           size:'small' },
  { title:'Dark Coquette Aesthetics I\'m Obsessed With Right Now',cat:'style',  date:'25 Feb 2025', rating:null,  tags:['fashion','mood'],           size:'large' },
  { title:'Hades II Early Access — What the Underworld Looks Like',cat:'games', date:'22 Feb 2025', rating:'8.5', tags:['action','indie'],           size:'small' },
  { title:'My Favourite Manhwa of 2024 — The Full List',          cat:'manhwa', date:'20 Feb 2025', rating:null,  tags:['best-of','recs'],           size:'wide'  },
  { title:'Winter 2025 Anime — Ranked After Watching Everything', cat:'anime',  date:'18 Feb 2025', rating:null,  tags:['ranking','seasonal'],       size:'small' },
  { title:'The Outfits I\'d Wear If I Lived in a Manhwa Panel',   cat:'style',  date:'15 Feb 2025', rating:null,  tags:['fashion','manhwa'],         size:'small' },
  { title:'Genshin Impact Natlan — Worth Coming Back For?',       cat:'games',  date:'12 Feb 2025', rating:'7.5', tags:['gacha','review'],           size:'small' },
  { title:'A Sign of Affection — The Softest Romance Manga',      cat:'manga',  date:'9 Feb 2025',  rating:'9',   tags:['romance','slice-of-life'],  size:'small' },
];

const catLabels: Record<string,string> = { manhwa:'Manhwa', manga:'Manga', anime:'Anime', style:'Style', games:'Games' };
const catColor:  Record<string,string> = { manhwa:'var(--mg)', manga:'var(--gold)', anime:'var(--v2)', style:'var(--t)', games:'var(--mg2)' };

function fd(d:Date){ return d.toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'}); }
function rs(r:number|undefined){ return r!=null?`${r}/10`:''; }
---

<Base title="Blog" description="All posts — manga, manhwa, anime, style and games.">

<!-- ══ HERO ══ -->
<section id="blog-hero">
  <div class="bh-bg"></div>
  <div class="bh-vignette"></div>

  <!-- Rose window -->
  <svg class="bh-rose" viewBox="0 0 600 600" fill="none" aria-hidden="true">
    <circle cx="300" cy="300" r="292" stroke="rgba(232,0,106,.6)"  stroke-width="2"/>
    <circle cx="300" cy="300" r="238" stroke="rgba(232,0,106,.38)" stroke-width="1.2"/>
    <circle cx="300" cy="300" r="172" stroke="rgba(140,0,180,.32)" stroke-width="1"/>
    <circle cx="300" cy="300" r="106" stroke="rgba(232,0,106,.44)" stroke-width="1.2"/>
    <circle cx="300" cy="300" r="50"  stroke="rgba(232,0,106,.55)" stroke-width="1.2"/>
    <circle cx="300" cy="300" r="15"  fill="rgba(232,0,106,.38)"/>
    <line x1="300" y1="8"   x2="300" y2="592" stroke="rgba(232,0,106,.28)" stroke-width=".7"/>
    <line x1="8"   y1="300" x2="592" y2="300" stroke="rgba(232,0,106,.28)" stroke-width=".7"/>
    <line x1="55"  y1="55"  x2="545" y2="545" stroke="rgba(240,200,74,.18)" stroke-width=".5"/>
    <line x1="545" y1="55"  x2="55"  y2="545" stroke="rgba(240,200,74,.18)" stroke-width=".5"/>
    <g opacity=".42">
      {[0,45,90,135,180,225,270,315].map((deg,i)=>(
        <ellipse cx="300" cy="74" rx="14" ry="25"
          fill={i%3===0?'rgba(232,0,106,.3)':i%3===1?'rgba(240,200,74,.2)':'rgba(140,0,180,.24)'}
          transform={`rotate(${deg} 300 300)`}/>
      ))}
    </g>
  </svg>

  <!-- Gothic arch with heart -->
  <svg class="bh-arch" viewBox="0 0 380 520" fill="none" aria-hidden="true">
    <path d="M10 520 L10 160 Q190 8 370 160 L370 520" stroke="rgba(232,0,106,.4)" stroke-width="2" fill="none"/>
    <path d="M22 520 L22 167 Q190 26 358 167 L358 520" stroke="rgba(240,200,74,.22)" stroke-width=".7" fill="none" stroke-dasharray="4 8"/>
    <circle cx="190" cy="120" r="30" fill="rgba(232,0,106,.12)" stroke="rgba(240,200,74,.36)" stroke-width="1"/>
    <circle cx="143" cy="148" r="23" fill="rgba(140,0,180,.1)"  stroke="rgba(240,200,74,.24)" stroke-width=".7"/>
    <circle cx="237" cy="148" r="23" fill="rgba(232,0,106,.1)"  stroke="rgba(240,200,74,.24)" stroke-width=".7"/>
    <path d="M190 133 C190 133 181 127 181 121 C181 117.5 183.5 116 186 116 C187.8 116 190 118.5 190 118.5 C190 118.5 192.2 116 194 116 C196.5 116 199 117.5 199 121 C199 127 190 133 190 133Z" fill="rgba(232,0,106,.82)"/>
  </svg>

  <div class="bh-lh" style="top:22%"></div>
  <div class="bh-lh" style="bottom:26%"></div>
  <div class="bh-lv" style="left:7%"></div>
  <div class="bh-lv" style="right:7%"></div>

  <div class="bh-inner">
    <div class="bh-cross" aria-hidden="true">
      <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
        <line x1="24" y1="4" x2="24" y2="44" stroke="rgba(232,0,106,.75)" stroke-width="1.8"/>
        <line x1="4"  y1="24" x2="44" y2="24" stroke="rgba(232,0,106,.75)" stroke-width="1.8"/>
        <circle cx="24" cy="24" r="8" fill="rgba(232,0,106,.48)" stroke="rgba(240,200,74,.55)" stroke-width="1"/>
        <circle cx="24" cy="24" r="4" fill="rgba(255,140,200,.75)"/>
        <circle cx="24" cy="5"  r="3" fill="rgba(232,0,106,.52)"/>
        <circle cx="24" cy="43" r="3" fill="rgba(232,0,106,.52)"/>
        <circle cx="5"  cy="24" r="3" fill="rgba(240,200,74,.48)"/>
        <circle cx="43" cy="24" r="3" fill="rgba(240,200,74,.48)"/>
      </svg>
    </div>
    <div class="bh-eyebrow"><div class="bhe-l"></div>all posts<div class="bhe-r"></div></div>
    <h1 class="bh-title" id="blog-title-el"></h1>
    <nav class="bh-filters">
      <a class="bhf bhf-active" href="/blog">All</a>
      <a class="bhf" href="/category/manhwa">Manhwa</a>
      <a class="bhf" href="/category/manga">Manga</a>
      <a class="bhf" href="/category/anime">Anime</a>
      <a class="bhf" href="/category/style">Style</a>
      <a class="bhf" href="/category/games">Games</a>
    </nav>
  </div>
  <div class="bh-scroll" aria-hidden="true"><div class="bh-scroll-l"></div><div class="bh-scroll-t">scroll</div></div>
</section>

<div class="sg-strip"><div class="sg-strip-t" id="sgstrip"></div></div>
<div class="mq"><div class="mt" id="mtrack"></div></div>

<!-- Floating decorative elements — wand left, phone right -->




<!-- ══ FEATURED POST ══ -->
{featured && (
  <>
    <div class="section-lead"></div>
    <section id="blog-featured">
      <div class="inner-wrap">
        <div class="sec-head">
          <div class="sec-over"><div class="sec-rule"></div>latest post<div class="sec-rule"></div></div>
          <div class="sec-title">Featured</div>
        </div>
        <a class="feat-card" href={`/posts/${featured.slug}`}>
          <div class="feat-vis">
            <div class="feat-vis-glow"></div>
            <svg class="feat-window" viewBox="0 0 300 420" fill="none">
              <rect x="4" y="4" width="292" height="412" stroke="rgba(240,200,74,.62)" stroke-width="2.2" fill="none"/>
              <rect x="9" y="9" width="282" height="402" stroke="rgba(232,0,106,.22)" stroke-width=".8" fill="none"/>
              <path d="M4 148 Q150 4 296 148" fill="rgba(232,0,106,.1)" stroke="rgba(240,200,74,.6)" stroke-width="2"/>
              <circle cx="150" cy="88"  r="36" fill="rgba(232,0,106,.18)" stroke="rgba(240,200,74,.52)" stroke-width="1.5"/>
              <circle cx="100" cy="118" r="28" fill="rgba(140,0,180,.14)" stroke="rgba(240,200,74,.36)" stroke-width="1.1"/>
              <circle cx="200" cy="118" r="28" fill="rgba(232,0,106,.16)" stroke="rgba(240,200,74,.36)" stroke-width="1.1"/>
              <!-- Heart in trefoil -->
              <path d="M150 102 C150 102 140 95 140 88 C140 84 143 82 146.5 82 C148.5 82 150 84.5 150 84.5 C150 84.5 151.5 82 153.5 82 C157 82 160 84 160 88 C160 95 150 102 150 102Z" fill="rgba(255,255,255,.72)"/>
              <path d="M150 100 C150 100 141.5 94 141.5 88 C141.5 85 143.8 83.5 146.5 83.5 C148.2 83.5 150 86 150 86 C150 86 151.8 83.5 153.5 83.5 C156.2 83.5 158.5 85 158.5 88 C158.5 94 150 100 150 100Z" fill="rgba(232,0,106,.88)"/>
              <polygon points="150,150 200,192 150,234 100,192" fill="rgba(232,0,106,.15)" stroke="rgba(240,200,74,.5)" stroke-width="1.8"/>
              <rect x="12"  y="148" width="72" height="110" fill="rgba(232,0,106,.09)" stroke="rgba(240,200,74,.3)" stroke-width="1.1"/>
              <rect x="216" y="148" width="72" height="110" fill="rgba(140,0,180,.09)" stroke="rgba(240,200,74,.3)" stroke-width="1.1"/>
              <rect x="12"  y="268" width="88" height="76"  fill="rgba(240,200,74,.07)" stroke="rgba(240,200,74,.28)" stroke-width="1.1"/>
              <rect x="108" y="268" width="84" height="76"  fill="rgba(232,0,106,.1)"   stroke="rgba(240,200,74,.28)" stroke-width="1.1"/>
              <rect x="200" y="268" width="88" height="76"  fill="rgba(0,200,212,.07)"  stroke="rgba(240,200,74,.28)" stroke-width="1.1"/>
              <rect x="12"  y="352" width="276" height="60" fill="rgba(232,0,106,.07)"  stroke="rgba(240,200,74,.24)" stroke-width="1.1"/>
              <line x1="150" y1="148" x2="150" y2="410" stroke="rgba(240,200,74,.38)" stroke-width="1.4"/>
              <line x1="12"  y1="266" x2="288" y2="266" stroke="rgba(240,200,74,.28)" stroke-width="1.1"/>
              <line x1="12"  y1="350" x2="288" y2="350" stroke="rgba(240,200,74,.24)" stroke-width="1"/>
            </svg>
            <div class="feat-badge">✦ Latest</div>
            <div class="feat-c-tl"></div>
            <div class="feat-c-br"></div>
          </div>
          <div class="feat-div"></div>
          <div class="feat-body">
            <div class="feat-cat" style={`color:${catColor[featured.data.category]??'var(--mg)'}`}>
              {catLabels[featured.data.category]??featured.data.category}
              {featured.data.spoilers && <span class="feat-spoiler">⚠ Spoilers</span>}
            </div>
            <h2 class="feat-title">{featured.data.title}</h2>
            <p class="feat-desc">{featured.data.description}</p>
            <div class="feat-meta">{fd(featured.data.pubDate)}{rs(featured.data.rating)&&` · ${rs(featured.data.rating)}`}</div>
            {featured.data.tags.length>0 && <div class="feat-tags">{featured.data.tags.slice(0,5).map(t=><span class="feat-tag">#{t}</span>)}</div>}
            <div class="feat-cta"><div class="feat-cta-l"></div><span>Read post</span><svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
          </div>
        </a>
      </div>
    </section>
  </>
)}

<!-- ══ MAGAZINE GRID ══ -->
<div class="section-lead"></div>
<section id="blog-grid">
  <div class="inner-wrap">
    <div class="sec-head">
      <div class="sec-over"><div class="sec-rule"></div>archive<div class="sec-rule"></div></div>
      <div class="sec-title">All posts</div>
    </div>

    <div class="mag-grid">
      <!-- Real posts -->
      {rest.map((post,i) => {
        const variant = (i%7)+1;
        const ac = catColor[post.data.category]??'var(--mg)';
        return (
          <a class={`mg-card mg-v${variant}`} href={`/posts/${post.slug}`} style={`--ac:${ac}`}>
            <div class="mg-stripe"></div>
            <div class="mg-body">
              <div class="mg-cat">{catLabels[post.data.category]??post.data.category}</div>
              <h3 class="mg-title">{post.data.title}</h3>
              {(variant===1||variant===4)&&<p class="mg-desc">{post.data.description}</p>}
              <div class="mg-foot">
                <span class="mg-date">{fd(post.data.pubDate)}</span>
                {post.data.rating!=null&&<span class="mg-rating">{post.data.rating}/10</span>}
              </div>
              {post.data.tags.length>0&&<div class="mg-tags">{post.data.tags.slice(0,3).map(t=><span class="mg-tag">#{t}</span>)}</div>}
            </div>
            <div class="mg-diamond" aria-hidden="true"></div>
            <div class="mg-shine"   aria-hidden="true"></div>
            <div class="mg-arrow"   aria-hidden="true"><svg width="13" height="13" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
          </a>
        );
      })}

      <!-- Sample posts -->
      {sample.map((post,i) => {
        const variant = ((rest.length+i)%7)+1;
        const ac = catColor[post.cat]??'var(--mg)';
        return (
          <div class={`mg-card mg-v${variant} mg-sample`} style={`--ac:${ac}`}>
            <div class="mg-stripe"></div>
            <div class="mg-body">
              <div class="mg-cat">{catLabels[post.cat]??post.cat}</div>
              <h3 class="mg-title">{post.title}</h3>
              <div class="mg-foot">
                <span class="mg-date">{post.date}</span>
                {post.rating&&<span class="mg-rating">{post.rating}/10</span>}
              </div>
              {post.tags.length>0&&<div class="mg-tags">{post.tags.map(t=><span class="mg-tag">#{t}</span>)}</div>}
            </div>
            <div class="mg-diamond" aria-hidden="true"></div>
            <div class="mg-shine"   aria-hidden="true"></div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<!-- ══ MAGICAL TV — AD SECTION ══ -->
<div class="section-lead"></div>
<section id="blog-tv">
  <div class="inner-wrap tv-wrap">

    <!-- Left decorative panel -->
    <div class="tv-side tv-side-l" aria-hidden="true">
      <svg viewBox="0 0 160 400" fill="none" width="160" height="400">
        <path d="M20 400 L20 120 Q80 10 140 120 L140 400" stroke="rgba(232,0,106,.32)" stroke-width="2" fill="rgba(232,0,106,.04)"/>
        <path d="M30 400 L30 126 Q80 26 130 126 L130 400" stroke="rgba(240,200,74,.2)" stroke-width=".8" fill="none" stroke-dasharray="4 7"/>
        <circle cx="80" cy="82"  r="28" fill="rgba(232,0,106,.16)" stroke="rgba(240,200,74,.44)" stroke-width="1.3"/>
        <circle cx="50" cy="106" r="20" fill="rgba(140,0,180,.12)" stroke="rgba(240,200,74,.3)"  stroke-width="1"/>
        <circle cx="110" cy="106" r="20" fill="rgba(232,0,106,.14)" stroke="rgba(240,200,74,.3)" stroke-width="1"/>
        <!-- Heart -->
        <path d="M80 96 C80 96 72 91 72 85 C72 81.5 74.5 80 77 80 C78.5 80 80 82 80 82 C80 82 81.5 80 83 80 C85.5 80 88 81.5 88 85 C88 91 80 96 80 96Z" fill="rgba(232,0,106,.85)"/>
        <polygon points="80,118 106,140 80,162 54,140" fill="rgba(232,0,106,.13)" stroke="rgba(240,200,74,.38)" stroke-width="1.3"/>
        <rect x="24" y="116" width="42" height="44" fill="rgba(232,0,106,.08)" stroke="rgba(240,200,74,.26)" stroke-width=".9"/>
        <rect x="94" y="116" width="42" height="44" fill="rgba(140,0,180,.08)" stroke="rgba(240,200,74,.26)" stroke-width=".9"/>
        <rect x="24" y="168" width="112" height="54" fill="rgba(240,200,74,.05)" stroke="rgba(240,200,74,.22)" stroke-width=".9"/>
        <rect x="24" y="230" width="54" height="64" fill="rgba(232,0,106,.07)" stroke="rgba(240,200,74,.2)"  stroke-width=".9"/>
        <rect x="82" y="230" width="54" height="64" fill="rgba(140,0,180,.07)" stroke="rgba(240,200,74,.2)"  stroke-width=".9"/>
        <rect x="24" y="302" width="112" height="95" fill="rgba(232,0,106,.06)" stroke="rgba(240,200,74,.18)" stroke-width=".9"/>
        <line x1="80" y1="116" x2="80" y2="398" stroke="rgba(240,200,74,.3)"  stroke-width="1.2"/>
        <line x1="24" y1="166" x2="136" y2="166" stroke="rgba(240,200,74,.24)" stroke-width="1"/>
        <line x1="24" y1="228" x2="136" y2="228" stroke="rgba(240,200,74,.2)"  stroke-width=".9"/>
        <line x1="24" y1="300" x2="136" y2="300" stroke="rgba(240,200,74,.18)" stroke-width=".8"/>
        <circle cx="20"  cy="400" r="6" fill="rgba(240,200,74,.45)"/>
        <circle cx="140" cy="400" r="6" fill="rgba(240,200,74,.45)"/>
      </svg>
    </div>

    <!-- CENTER: the TV -->
    <div class="tv-center">
      <div class="tv-heading">
        <div class="sec-over"><div class="sec-rule"></div>support the blog<div class="sec-rule"></div></div>
        <div class="sec-title">On Air</div>
        <p class="tv-sub">Click the power button to tune in.</p>
      </div>

      <div class="tv-device-wrap" id="tv-device">
        <div class="tv-device-glow"></div>
        <svg class="tv-svg" viewBox="0 0 440 340" fill="none">
          <defs>
            <linearGradient id="tvb" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%"   stop-color="#3a1445"/>
              <stop offset="100%" stop-color="#1e0828"/>
            </linearGradient>
            <linearGradient id="tvg" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%"   stop-color="#fff2a0"/>
              <stop offset="100%" stop-color="#906000"/>
            </linearGradient>
            <linearGradient id="tv-soff" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%"   stop-color="#06000e"/>
              <stop offset="100%" stop-color="#03000a"/>
            </linearGradient>
            <radialGradient id="tv-son" cx="50%" cy="42%" r="58%">
              <stop offset="0%"   stop-color="#38006a"/>
              <stop offset="45%"  stop-color="#22003a"/>
              <stop offset="100%" stop-color="#0c0018"/>
            </radialGradient>
            <clipPath id="tv-screen-clip"><rect x="36" y="30" width="308" height="218" rx="10"/></clipPath>
          </defs>

          <!-- Legs -->
          <rect x="136" y="310" width="20" height="28" rx="5" fill="rgba(42,14,52,.95)" stroke="rgba(240,200,74,.45)" stroke-width="1.5"/>
          <rect x="284" y="310" width="20" height="28" rx="5" fill="rgba(42,14,52,.95)" stroke="rgba(240,200,74,.45)" stroke-width="1.5"/>
          <rect x="122" y="332" width="52" height="7"  rx="3.5" fill="url(#tvg)" stroke="rgba(255,245,160,.45)" stroke-width="1"/>
          <rect x="266" y="332" width="52" height="7"  rx="3.5" fill="url(#tvg)" stroke="rgba(255,245,160,.45)" stroke-width="1"/>

          <!-- Body -->
          <rect x="6" y="14" width="428" height="300" rx="22" fill="url(#tvb)"/>
          <rect x="6" y="14" width="428" height="300" rx="22" fill="none" stroke="rgba(255,255,255,.14)" stroke-width="1.2"/>
          <rect x="6" y="14" width="428" height="300" rx="22" fill="none" stroke="url(#tvg)" stroke-width="3"/>
          <!-- Left highlight edge -->
          <path d="M6 36 Q6 14 28 14 L28 314 Q6 314 6 292 Z" fill="rgba(255,255,255,.06)"/>

          <!-- Antennas -->
          <rect x="116" y="2"  width="9"  height="38" rx="4.5" fill="rgba(255,200,235,.8)" stroke="rgba(255,160,210,.4)" stroke-width=".9"/>
          <rect x="315" y="2"  width="9"  height="38" rx="4.5" fill="rgba(255,200,235,.8)" stroke="rgba(255,160,210,.4)" stroke-width=".9"/>
          <rect x="113" y="36" width="15" height="7"  rx="3.5" fill="url(#tvg)"/>
          <rect x="312" y="36" width="15" height="7"  rx="3.5" fill="url(#tvg)"/>
          <!-- Antenna tip stars -->
          <path d="M120.5 4 L122 9 L127 7.5 L124.5 12 L130 13 L125.5 16.5 L128 22 L123 20 L122.5 26 L120.5 21 L118.5 26 L118 20 L113 22 L115.5 16.5 L111 13 L116.5 12 L114 7.5 L119 9 Z" fill="rgba(240,200,74,.9)"/>
          <path d="M320 4 L321.5 9 L326.5 7.5 L324 12 L329.5 13 L325 16.5 L327.5 22 L322.5 20 L322 26 L320 21 L318 26 L317.5 20 L312.5 22 L315 16.5 L310.5 13 L316 12 L313.5 7.5 L318.5 9 Z" fill="rgba(240,200,74,.9)"/>
          <!-- Hearts in antenna stars -->
          <path d="M120.5 17 C120.5 17 117.5 15 117.5 13 C117.5 12 118.3 11.4 119.2 11.4 C119.9 11.4 120.5 12.2 120.5 12.2 C120.5 12.2 121.1 11.4 121.8 11.4 C122.7 11.4 123.5 12 123.5 13 C123.5 15 120.5 17 120.5 17Z" fill="rgba(232,0,106,.9)"/>
          <path d="M320 17 C320 17 317 15 317 13 C317 12 317.8 11.4 318.7 11.4 C319.4 11.4 320 12.2 320 12.2 C320 12.2 320.6 11.4 321.3 11.4 C322.2 11.4 323 12 323 13 C323 15 320 17 320 17Z" fill="rgba(232,0,106,.9)"/>

          <!-- Screen bezel + screen -->
          <rect x="28" y="22" width="324" height="234" rx="14" fill="rgba(4,0,12,.95)" stroke="url(#tvg)" stroke-width="2.5"/>
          <rect class="tv-screen" x="36" y="30" width="308" height="218" rx="10" fill="url(#tv-soff)"/>
          <!-- Glass reflection -->
