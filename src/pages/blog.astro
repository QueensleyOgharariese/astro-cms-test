<style>
/* ══ HERO ══ */
#blog-hero{min-height:72vh;position:relative;overflow:hidden;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:100px 52px 56px}
.bh-bg{position:absolute;inset:0;background:radial-gradient(ellipse 60% 55% at 50% 45%,rgba(232,0,106,.18) 0%,transparent 62%),radial-gradient(ellipse 30% 35% at 12% 20%,rgba(140,0,180,.1) 0%,transparent 55%),linear-gradient(180deg,var(--dark) 0%,var(--dark2) 55%,var(--dark) 100%)}
.bh-vignette{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%,transparent 30%,rgba(0,0,0,.7) 100%);z-index:1}
.bh-rose{position:absolute;z-index:2;top:50%;left:50%;transform:translate(-50%,-50%);width:min(80vmin,600px);height:min(80vmin,600px);pointer-events:none;animation:rbreath 6s ease-in-out infinite}
@keyframes rbreath{0%,100%{opacity:.22}50%{opacity:.34}}
.bh-arch{position:absolute;z-index:3;top:50%;left:50%;transform:translate(-50%,-50%);width:min(44vmin,380px);height:min(60vmin,520px);pointer-events:none}
.bh-lh{position:absolute;left:0;right:0;height:2px;z-index:4;pointer-events:none;background:linear-gradient(90deg,transparent,rgba(240,200,74,.28),rgba(232,0,106,.45),rgba(240,200,74,.28),transparent)}
.bh-lv{position:absolute;top:0;bottom:0;width:2px;z-index:4;pointer-events:none;background:linear-gradient(180deg,transparent,rgba(232,0,106,.28),rgba(240,200,74,.32),rgba(232,0,106,.28),transparent)}
.bh-inner{position:relative;z-index:10;text-align:center;display:flex;flex-direction:column;align-items:center}
.bh-cross{margin-bottom:18px;filter:drop-shadow(0 0 12px rgba(232,0,106,.6));animation:cpulse 3.5s ease-in-out infinite}
@keyframes cpulse{0%,100%{filter:drop-shadow(0 0 12px rgba(232,0,106,.5))}50%{filter:drop-shadow(0 0 28px rgba(255,68,153,.9))}}
.bh-eyebrow{font-family:var(--font-heading);font-size:.46rem;letter-spacing:.52em;text-transform:uppercase;color:var(--gold);margin-bottom:14px;display:flex;align-items:center;gap:12px;opacity:0;animation:fadeup .7s ease .1s forwards}
.bhe-l{height:1px;width:36px;background:linear-gradient(90deg,transparent,var(--gold))}
.bhe-r{height:1px;width:36px;background:linear-gradient(270deg,transparent,var(--gold))}
@keyframes fadeup{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
.bh-title{font-family:var(--font-display);font-size:clamp(3rem,9vw,7.5rem);font-weight:300;font-style:italic;line-height:.92;margin-bottom:28px;background:linear-gradient(135deg,var(--mg5) 0%,var(--mg4) 22%,var(--mg3) 44%,var(--gold2) 62%,var(--mg3) 78%,var(--mg5) 100%);background-size:300% 300%;-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:shimmer-t 5s ease-in-out infinite,titlereveal .9s cubic-bezier(.77,0,.175,1) .05s both}
@keyframes shimmer-t{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
@keyframes titlereveal{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:none}}
.bh-filters{display:flex;gap:3px;flex-wrap:wrap;justify-content:center;opacity:0;animation:fadeup .8s ease .4s forwards}
.bhf{font-family:var(--font-heading);font-size:.44rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,240,248,.62);padding:8px 18px;text-decoration:none;transition:all .22s;border:1px solid transparent;position:relative}
.bhf::after{content:'';position:absolute;bottom:0;left:10px;right:10px;height:1px;background:linear-gradient(90deg,var(--mg),var(--gold));transform:scaleX(0);transform-origin:left;transition:transform .3s}
.bhf:hover{color:var(--mg4)}.bhf:hover::after{transform:scaleX(1)}
.bhf-active{color:var(--mg4);border-color:rgba(232,0,106,.28);background:rgba(232,0,106,.08)}.bhf-active::after{transform:scaleX(1)}
.bh-scroll{position:absolute;bottom:22px;left:50%;transform:translateX(-50%);z-index:10;display:flex;flex-direction:column;align-items:center;gap:5px;opacity:0;animation:fadeup .8s ease .8s forwards}
.bh-scroll-l{width:1px;height:38px;background:linear-gradient(180deg,transparent,var(--mg2));animation:scg 2.3s ease-in-out infinite}
@keyframes scg{0%{height:0;opacity:0}55%{height:38px;opacity:1}100%{height:38px;opacity:0}}
.bh-scroll-t{font-family:var(--font-heading);font-size:.44rem;letter-spacing:.36em;text-transform:uppercase;color:rgba(232,0,106,.45)}

/* floating deco removed */
@keyframes fd-float{0%,100%{transform:translateY(0) rotate(-3deg)}50%{transform:translateY(-16px) rotate(3deg)}}
.fd-sym{position:absolute;font-family:var(--font-display);font-size:1rem;color:var(--mg3);opacity:0;animation:fd-sym-anim var(--d,2s) ease-out infinite var(--dl,0s);left:var(--x,20px);top:var(--y,0px);pointer-events:none}
@keyframes fd-sym-anim{0%{opacity:0;transform:scale(0) rotate(0deg)}35%{opacity:.9;transform:scale(1.2) rotate(20deg)}100%{opacity:0;transform:scale(.2) rotate(40deg) translateY(-16px)}}
.fd-spark{border-radius:50%;animation:wspk var(--d,1.5s) ease-out infinite var(--dl,0s)}
@keyframes wspk{0%{opacity:0;transform:translate(0,0) scale(0)}35%{opacity:1;transform:translate(var(--tx,4px),var(--ty,-8px)) scale(1.2)}100%{opacity:0;transform:translate(var(--tx2,8px),var(--ty2,-18px)) scale(.1)}}

/* ══ INNER WRAP ══ */
.inner-wrap{max-width:1200px;margin:0 auto;padding:72px 52px}

/* ══ FEATURED ══ */
#blog-featured{background:var(--dark2)}
.feat-card{display:grid;grid-template-columns:1.1fr 4px 1fr;border:2px solid rgba(232,0,106,.2);text-decoration:none;overflow:hidden;transition:border-color .4s}
.feat-card:hover{border-color:rgba(232,0,106,.65)}
.feat-card:hover .feat-window{transform:scale(1.02) translateY(-6px);filter:drop-shadow(0 0 28px rgba(232,0,106,.4))}
.feat-card:hover .feat-title{color:#fff;text-shadow:0 0 18px rgba(232,0,106,.35)}
.feat-card:hover .feat-cta-l{width:50px}
.feat-vis{background:linear-gradient(145deg,var(--dark3),var(--dark2));min-height:420px;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
.feat-vis-glow{position:absolute;inset:0;background:radial-gradient(ellipse at 42% 48%,rgba(232,0,106,.22) 0%,transparent 55%)}
.feat-window{width:min(300px,85%);height:auto;position:relative;z-index:2;transition:transform .5s,filter .5s;filter:drop-shadow(0 0 18px rgba(232,0,106,.25))}
.feat-badge{position:absolute;top:20px;left:20px;z-index:6;font-family:var(--font-heading);font-size:.44rem;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);border:1px solid rgba(240,200,74,.38);background:rgba(26,8,32,.85);padding:4px 11px;backdrop-filter:blur(10px)}
.feat-c-tl{position:absolute;top:14px;left:14px;width:20px;height:20px;border-top:1.5px solid rgba(240,200,74,.42);border-left:1.5px solid rgba(240,200,74,.42);z-index:5}
.feat-c-br{position:absolute;bottom:14px;right:14px;width:20px;height:20px;border-bottom:1.5px solid rgba(240,200,74,.42);border-right:1.5px solid rgba(240,200,74,.42);z-index:5}
.feat-div{background:var(--lead);border-left:1px solid rgba(240,200,74,.2);border-right:1px solid rgba(240,200,74,.2)}
.feat-body{background:var(--dark4);padding:52px 44px;display:flex;flex-direction:column;justify-content:center;position:relative}
.feat-body::before{content:'';position:absolute;left:0;top:10%;bottom:10%;width:1px;background:linear-gradient(180deg,transparent,rgba(232,0,106,.28),transparent)}
.feat-cat{font-family:var(--font-heading);font-size:.44rem;letter-spacing:.2em;text-transform:uppercase;margin-bottom:16px;display:flex;align-items:center;gap:10px}
.feat-spoiler{font-size:.42rem;background:rgba(232,0,106,.14);border:1px solid rgba(232,0,106,.32);padding:2px 7px;color:var(--mg3)}
.feat-title{font-family:var(--font-display);font-size:clamp(1.7rem,2.5vw,2.2rem);font-weight:400;color:var(--mg5);line-height:1.18;margin-bottom:16px;transition:all .3s}
.feat-desc{font-style:italic;font-size:.93rem;color:rgba(255,180,220,.82);line-height:1.9;margin-bottom:20px}
.feat-meta{font-family:var(--font-heading);font-size:.44rem;letter-spacing:.12em;color:rgba(220,160,200,.68);margin-bottom:16px}
.feat-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:22px}
.feat-tag{font-family:var(--font-heading);font-size:.42rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(232,0,106,.72);border:1px solid rgba(232,0,106,.18);padding:2px 8px}
.feat-cta{font-family:var(--font-heading);font-size:.44rem;letter-spacing:.2em;text-transform:uppercase;color:var(--mg3);display:flex;align-items:center;gap:10px;transition:gap .3s}
.feat-cta-l{width:26px;height:1px;background:linear-gradient(90deg,var(--mg),var(--gold));transition:width .3s}

/* ══ MAGAZINE GRID ══ */
#blog-grid{background:var(--dark3)}
.mag-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  grid-auto-rows:200px;
  gap:4px;
  background:rgba(232,0,106,.07);
  margin-top:44px;
}
/* 7 variants for visual rhythm */
.mg-v1{grid-column:span 2;grid-row:span 2} /* large square */
.mg-v2{grid-column:span 1;grid-row:span 1} /* small */
.mg-v3{grid-column:span 1;grid-row:span 1} /* small */
.mg-v4{grid-column:span 2;grid-row:span 1} /* wide */
.mg-v5{grid-column:span 1;grid-row:span 1} /* small */
.mg-v6{grid-column:span 1;grid-row:span 2} /* tall */
.mg-v7{grid-column:span 2;grid-row:span 1} /* wide */

.mg-card{
  background:var(--dark4);position:relative;overflow:hidden;
  display:flex;flex-direction:column;
  text-decoration:none;cursor:pointer;
  transition:background .26s;
  border:1px solid rgba(232,0,106,.07);
}
.mg-sample{opacity:.72;cursor:default}
.mg-card:not(.mg-sample):hover{background:rgba(55,14,65,.98)}
.mg-card:not(.mg-sample):hover .mg-title{color:#fff}
.mg-card:not(.mg-sample):hover .mg-arrow{opacity:1;transform:translateX(4px)}
.mg-card:not(.mg-sample):hover .mg-diamond{opacity:1;transform:translate(-50%,-50%) scale(1.6)}
.mg-card:not(.mg-sample):hover .mg-shine{left:120%}

.mg-stripe{height:5px;flex-shrink:0;background:linear-gradient(90deg,var(--ac),color-mix(in srgb,var(--ac) 60%,#fff 40%),var(--ac))}
.mg-body{padding:16px 18px;flex:1;display:flex;flex-direction:column;justify-content:center;min-width:0;position:relative;z-index:2}
.mg-cat{font-family:var(--font-heading);font-size:.42rem;letter-spacing:.18em;text-transform:uppercase;color:var(--ac);margin-bottom:8px;display:block}
.mg-title{font-family:var(--font-display);font-size:1rem;color:var(--mg5);line-height:1.3;margin-bottom:8px;transition:color .25s;overflow:hidden;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical}
.mg-v1 .mg-title{font-size:1.35rem;-webkit-line-clamp:5;line-height:1.25}
.mg-v6 .mg-title{-webkit-line-clamp:4}
.mg-v4 .mg-title,.mg-v7 .mg-title{-webkit-line-clamp:2}
.mg-desc{font-style:italic;font-size:.82rem;color:rgba(255,180,220,.72);line-height:1.68;margin-bottom:8px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.mg-foot{display:flex;align-items:center;gap:10px;margin-bottom:6px}
.mg-date{font-family:var(--font-heading);font-size:.42rem;letter-spacing:.1em;color:rgba(220,160,200,.68)}
.mg-rating{font-family:var(--font-heading);font-size:.42rem;letter-spacing:.08em;color:var(--gold);background:rgba(240,200,74,.1);border:1px solid rgba(240,200,74,.22);padding:1px 7px}
.mg-tags{display:flex;gap:4px;flex-wrap:wrap}
.mg-tag{font-family:var(--font-heading);font-size:.38rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(232,0,106,.65);border:1px solid rgba(232,0,106,.18);padding:1px 6px}
.mg-diamond{position:absolute;top:18px;right:16px;width:9px;height:9px;clip-path:polygon(50% 0%,100% 50%,50% 100%,0% 50%);background:var(--ac);opacity:.28;transition:opacity .25s,transform .25s;transform:translate(0,0) scale(1)}
.mg-shine{position:absolute;top:0;left:-100%;width:55%;height:100%;background:linear-gradient(90deg,transparent,rgba(232,0,106,.06),transparent);transition:left .55s;pointer-events:none}
.mg-arrow{position:absolute;bottom:12px;right:12px;color:var(--mg);opacity:0;transition:all .25s}

/* ══ TV AD SECTION ══ */
#blog-tv{background:var(--dark2)}
.tv-wrap{display:grid;grid-template-columns:180px 1fr 180px;align-items:center;gap:28px;padding-top:52px;padding-bottom:72px}
.tv-side{opacity:.55;transition:opacity .3s;align-self:stretch;display:flex;align-items:center}
.tv-side:hover{opacity:.8}
.tv-side svg{width:100%;height:auto}
.tv-center{display:flex;flex-direction:column;align-items:center;gap:28px}
.tv-heading{text-align:center}
.tv-sub{font-family:var(--font-display);font-style:italic;font-size:.92rem;color:rgba(255,180,220,.55);margin-top:8px}
.tv-device-wrap{position:relative;display:flex;flex-direction:column;align-items:center;gap:10px;animation:tv-float 6s ease-in-out infinite;filter:drop-shadow(0 0 22px rgba(232,0,106,.55)) drop-shadow(0 0 50px rgba(232,0,106,.22))}
@keyframes tv-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
.tv-device-glow{position:absolute;width:500px;height:300px;border-radius:50%;background:radial-gradient(ellipse,rgba(232,0,106,.18) 0%,rgba(160,0,180,.1) 40%,transparent 70%);animation:tvglow 4s ease-in-out infinite;pointer-events:none;top:50%;left:50%;transform:translate(-50%,-50%)}
@keyframes tvglow{0%,100%{opacity:.55;transform:translate(-50%,-50%) scale(1)}50%{opacity:1;transform:translate(-50%,-50%) scale(1.08)}}
.tv-svg{width:min(440px,100%);height:auto;position:relative;z-index:2}
.tv-caption{font-family:var(--font-heading);font-size:.46rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(232,0,106,.45);text-align:center}

/* TV animations */
.tv-screen{transition:fill .45s}
.tv-on-content{transition:opacity .65s}
.tv-blink{animation:tv-blink 1.2s step-end infinite}
@keyframes tv-blink{0%,100%{opacity:1}50%{opacity:0}}
.tv-ind-1{animation:tv-ind 3s ease-in-out infinite}
.tv-ind-2{animation:tv-ind 3s ease-in-out infinite .4s}
.tv-ind-3{animation:tv-ind 3s ease-in-out infinite .8s}
@keyframes tv-ind{0%,100%{opacity:.3}50%{opacity:.9}}
.tv-power-btn{cursor:pointer;transition:filter .2s}
.tv-power-btn:hover{filter:brightness(1.5)}

/* ══ LIGHT MODE ══ */
body.light #blog-featured{background:var(--dark2)}
body.light .feat-vis{background:linear-gradient(145deg,#f2e4f8,#fce8f5)}
body.light .feat-body{background:#ffffff}
body.light .feat-title{color:#1a0828}
body.light .feat-card:hover .feat-title{color:#000;text-shadow:none}
body.light .feat-desc{color:rgba(60,10,80,.65)}
body.light #blog-grid{background:var(--dark3)}
body.light .mag-grid{background:rgba(200,100,180,.12)}
body.light .mg-card{background:#ffffff;border-color:rgba(200,100,180,.1)}
body.light .mg-card:not(.mg-sample):hover{background:#faf0ff}
body.light .mg-title{color:#1a0828}
body.light .mg-desc{color:rgba(60,10,80,.62)}
body.light #blog-tv{background:var(--dark2)}

/* ══ RESPONSIVE ══ */
@media(max-width:1100px){
  .inner-wrap{padding:52px 36px}
}
@media(max-width:1100px){
  .inner-wrap{padding:52px 36px}
}
@media(max-width:860px){
  .feat-card{grid-template-columns:1fr}
  .feat-div{display:none}
  .feat-vis{min-height:200px}
  .feat-body{padding:28px 22px}
  .feat-title{font-size:1.55rem}
  .mag-grid{grid-template-columns:repeat(2,1fr);grid-auto-rows:155px}
  .mg-v1{grid-column:span 2;grid-row:span 2}
  .mg-v4,.mg-v7{grid-column:span 2;grid-row:span 1}
  .mg-v6{grid-row:span 1}
  .tv-wrap{grid-template-columns:1fr;padding-left:20px;padding-right:20px}
  .tv-side{display:none}
  .inner-wrap{padding:40px 20px}
  #blog-hero{padding:80px 20px 48px}
  .feat-wrap{padding:48px 20px}
}
@media(max-width:640px){
  .mag-grid{grid-template-columns:1fr;grid-auto-rows:auto}
  .mg-v1,.mg-v4,.mg-v6,.mg-v7{grid-column:span 1;grid-row:span 1}
  .mg-card{min-height:130px}
  .bhf{padding:6px 10px;font-size:.42rem}
  .bh-filters{gap:2px}
  .sec-title{font-size:clamp(1.6rem,6vw,2.4rem)}
}
@media(max-width:400px){
  .bhf{padding:5px 8px;font-size:.4rem;letter-spacing:.1em}
  .mag-grid{gap:3px}
  .inner-wrap{padding:32px 14px}
}
</style>

<script>
/* Blog title animation */
(function(){
  const el=document.getElementById('blog-title-el');
  if(!el)return;
  'Blog'.split('').forEach((ch,i)=>{
    const s=document.createElement('span');
    s.style.cssText=`display:inline-block;opacity:0;transform:translateY(100%) rotate(8deg);animation:letter-fall .65s cubic-bezier(.34,1.56,.64,1) ${0.1+i*.1}s forwards`;
    s.textContent=ch;
    el.appendChild(s);
  });
})();

/* TV power button */
(function(){
  const btn=document.getElementById('tv-power');
  const screen=document.querySelector('.tv-screen') as SVGRectElement|null;
  const content=document.querySelector('.tv-on-content') as SVGGElement|null;
  if(!btn||!screen||!content)return;
  let on=false;

  function turnOn(){
    on=true;
    screen.style.fill='rgba(255,255,255,.4)';
    setTimeout(()=>{
      screen.style.fill='rgba(255,255,255,.06)';
      setTimeout(()=>{
        screen.setAttribute('fill','url(#tv-son)');
        screen.style.fill='';
        content.style.opacity='1';
      },80);
    },55);
  }
  function turnOff(){
    on=false;
    content.style.opacity='0';
    screen.style.fill='rgba(255,255,255,.55)';
    setTimeout(()=>{ screen.style.fill=''; screen.setAttribute('fill','url(#tv-soff)'); },120);
  }

  btn.addEventListener('click',()=>on?turnOff():turnOn());
  // Auto turn on after 2.5s
  setTimeout(turnOn, 2500);
  // Random flicker
  setInterval(()=>{
    if(on&&Math.random()<.12){ turnOff(); setTimeout(turnOn, 350+Math.random()*500); }
  },6000);
})();
</script>