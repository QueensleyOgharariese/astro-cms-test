---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const searchData = posts.map(p => ({
  slug: p.slug,
  title: p.data.title,
  category: p.data.category,
  tags: p.data.tags,
  description: p.data.description,
  pubDate: p.data.pubDate.toISOString().slice(0, 10),
  rating: p.data.rating,
}));

const catLabels: Record<string, string> = {
  manhwa: 'Manhwa', manga: 'Manga', otome: 'Otome Game', discussion: 'Discussion'
};
---
<Base title="Search">

<div class="search-page">
  <div class="search-header">
    <div class="search-header-bg"></div>
    <div class="search-header-inner">
      <h1 class="search-title">Search</h1>
      <div class="search-bar-wrap">
        <input
          type="text"
          id="search-input"
          class="search-input"
          placeholder="Search posts, tags, categories..."
          autocomplete="off"
        />
        <div class="search-icon">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <circle cx="8" cy="8" r="5.5" stroke="rgba(224,0,154,.6)" stroke-width="1.5"/>
            <line x1="12.5" y1="12.5" x2="16" y2="16" stroke="rgba(224,0,154,.6)" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
      </div>
    </div>
    <div class="search-lead"></div>
  </div>

  <div class="search-body">
    <div class="search-status" id="search-status"></div>
    <div class="search-results" id="search-results"></div>
  </div>
</div>

<script define:vars={{ searchData, catLabels }}>
const input  = document.getElementById('search-input');
const status = document.getElementById('search-status');
const results = document.getElementById('search-results');

function formatDate(iso) {
  const d = new Date(iso);
  return d.toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric' });
}

function renderCard(post, i) {
  return `
    <a class="post-card" href="/posts/${post.slug}"
      style="${i%2===0?'border-top-color:rgba(224,0,154,.55)':'border-top-color:rgba(240,200,74,.45)'}">
      <div class="post-card-cat">${catLabels[post.category] || post.category}</div>
      <div class="post-card-title">${post.title}</div>
      <div class="post-card-meta">${formatDate(post.pubDate)}${post.rating ? ' · ' + post.rating + '/10' : ''}</div>
      <div class="post-card-arrow">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </a>`;
}

function doSearch(query) {
  const q = query.trim().toLowerCase();
  if (!q) {
    status.textContent = '';
    results.innerHTML = '';
    return;
  }
  const found = searchData.filter(p =>
    p.title.toLowerCase().includes(q) ||
    p.description.toLowerCase().includes(q) ||
    p.category.toLowerCase().includes(q) ||
    p.tags.some(t => t.toLowerCase().includes(q))
  );
  status.textContent = found.length
    ? `${found.length} result${found.length !== 1 ? 's' : ''} for "${query}"`
    : `No results for "${query}"`;
  if (found.length === 0) {
    results.innerHTML = '<div class="search-empty"><p>Try different keywords, or browse by <a href="/tags">tag</a> or <a href="/category/manhwa">category</a>.</p></div>';
    return;
  }
  results.innerHTML = `<div class="search-grid">${found.map((p, i) => renderCard(p, i)).join('')}</div>`;
}

input.addEventListener('input', e => doSearch(e.target.value));

// Check URL params
const params = new URLSearchParams(window.location.search);
const q = params.get('q');
if (q) { input.value = q; doSearch(q); }
</script>

</Base>

<style>
.search-page { background: var(--dark2); min-height: 100vh; }
.search-header { background: linear-gradient(162deg, #08021a, #180628, #100420); padding: 72px 52px 60px; position: relative; overflow: hidden; text-align: center; }
.search-header-bg { position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 60%, rgba(224,0,154,.18) 0%, transparent 55%); }
.search-lead { position: absolute; bottom: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, transparent, var(--gold), var(--mg), var(--mg2), var(--mg), var(--gold), transparent); }
.search-header-inner { position: relative; z-index: 2; max-width: 700px; margin: 0 auto; }
.search-title { font-family: var(--font-display); font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 300; font-style: italic; color: var(--mg5); margin-bottom: 28px; }
.search-bar-wrap { position: relative; }
.search-input {
  width: 100%; padding: 16px 52px 16px 22px;
  font-family: var(--font-display); font-size: 1rem; font-style: italic;
  background: rgba(224,0,154,.08); border: 1px solid rgba(224,0,154,.35);
  color: var(--mg5); outline: none; transition: all .25s;
}
.search-input::placeholder { color: rgba(255,160,232,.3); }
.search-input:focus { border-color: rgba(224,0,154,.7); background: rgba(224,0,154,.12); box-shadow: 0 0 20px rgba(224,0,154,.2); }
.search-icon { position: absolute; right: 16px; top: 50%; transform: translateY(-50%); pointer-events: none; }

.search-body { max-width: 1100px; margin: 0 auto; padding: 40px 52px 80px; }
.search-status { font-family: var(--font-heading); font-size: .5rem; letter-spacing: .22em; text-transform: uppercase; color: rgba(224,0,154,.45); margin-bottom: 24px; min-height: 24px; }
.search-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 4px; background: rgba(224,0,154,.06); }
.search-empty { text-align: center; padding: 60px 0; }
.search-empty p { font-family: var(--font-display); font-style: italic; color: rgba(255,160,232,.4); font-size: 1rem; }
.search-empty a { color: var(--mg3); }

@media (max-width: 860px) {
  .search-header { padding: 56px 24px 48px; }
  .search-body { padding: 28px 24px 60px; }
  .search-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 540px) {
  .search-grid { grid-template-columns: 1fr; }
}
</style>
