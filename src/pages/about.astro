.sb-title{font-family:var(--font-display);font-size:1.1rem;font-weight:400;color:var(--mg5);margin-bottom:8px}
.sb-text{font-style:italic;font-size:.9rem;color:rgba(255,175,222,.62);line-height:1.9}
.story-divider{display:flex;align-items:center;gap:14px}
.sd-line{flex:1;height:1px;background:linear-gradient(90deg,rgba(240,200,74,.3),rgba(240,200,74,.05))}
.sd-line:last-child{background:linear-gradient(270deg,rgba(240,200,74,.3),rgba(240,200,74,.05))}

/* ══ SOCIAL SECTION ══ */
.social-wrap{padding:72px 52px;background:var(--dark3)}
.social-intro{font-family:var(--font-display);font-style:italic;font-size:1rem;color:rgba(255,175,222,.52);margin-top:8px;margin-bottom:44px}
