.sc-email{border-top-color:rgba(232,0,106,.55)}
.sc-youtube{border-top-color:rgba(255,0,0,.45)}
.sc-bg{position:absolute;inset:0;background:radial-gradient(ellipse at 20% 50%,rgba(232,0,106,.08) 0%,transparent 65%);opacity:0;transition:opacity .3s;pointer-events:none}
.sc-icon{width:40px;height:40px;display:flex;align-items:center;justify-content:center;border-radius:50%;background:rgba(255,255,255,.06);color:var(--mg3);flex-shrink:0;transition:color .25s}
.social-card:hover .sc-icon{color:var(--mg4)}
.sc-name{font-family:var(--font-heading);font-size:.44rem;letter-spacing:.18em;text-transform:uppercase;color:var(--mg4);margin-bottom:3px}
.sc-handle{font-family:var(--font-heading);font-size:.4rem;letter-spacing:.1em;color:var(--mg3);opacity:.65;margin-bottom:4px}
.sc-desc{font-style:italic;font-size:.82rem;color:rgba(255,165,220,.48);line-height:1.6}
.sc-arrow{color:var(--mg3);opacity:0;transition:all .22s;font-size:1.1rem;align-self:center}
.sc-sparkle{position:absolute;top:12px;right:14px;font-family:var(--font-display);font-size:.85rem;color:var(--gold);opacity:0;transition:opacity .3s;pointer-events:none}

 

