<script>
/* 3D tilt + parallax on magical card */
(function(){
  const card = document.getElementById('magical-card') as HTMLElement|null;
  if(!card) return;
  const face = card.querySelector('.mc-card-3d') as HTMLElement|null;
  const holo = card.querySelector('.mc-holo') as HTMLElement|null;
  if(!face) return;

  let raf = 0;

  card.addEventListener('mousemove', (e: MouseEvent) => {
    cancelAnimationFrame(raf);
    raf = requestAnimationFrame(() => {
      const rect = card.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width  - 0.5; // -0.5 to +0.5
      const y = (e.clientY - rect.top)  / rect.height - 0.5;
      // 3D tilt: rotate on both axes
      face.style.transform = `rotateY(${x * 18}deg) rotateX(${-y * 14}deg) translateZ(12px)`;
      face.style.transition = 'transform 0.1s ease-out, box-shadow 0.3s';
      // Holographic shimmer follows cursor
      if (holo) {
        holo.style.background = `radial-gradient(ellipse 80% 80% at ${(x+.5)*100}% ${(y+.5)*100}%,
          rgba(255,200,240,.18) 0%,
          rgba(200,160,255,.12) 25%,
          rgba(255,240,160,.1) 50%,
          transparent 70%)`;
      }
    });
  });

  card.addEventListener('mouseleave', () => {
    cancelAnimationFrame(raf);
    face.style.transform = '';
    face.style.transition = 'transform 0.6s cubic-bezier(.23,1,.32,1)';
    if (holo) {
      holo.style.background = '';
      holo.style.animation = 'holo-shift 4s ease-in-out infinite';
    }
  });

  // Subtle floating animation when not hovered
  card.style.animation = 'card-float 5s ease-in-out infinite';
})();
</script>