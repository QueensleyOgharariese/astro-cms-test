.ah-lv{position:absolute;top:0;bottom:0;width:2px;z-index:4;pointer-events:none;background:linear-gradient(180deg,transparent,rgba(232,0,106,.28),rgba(240,200,74,.3),rgba(232,0,106,.28),transparent)}
