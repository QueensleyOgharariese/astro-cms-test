.mc-footer-txt{font-family:var(--font-heading);font-size:.36rem;letter-spacing:.14em;text-transform:uppercase;color:rgba(200,140,180,.38)}
.mc-footer-id{font-family:var(--font-heading);font-size:.36rem;letter-spacing:.1em;color:rgba(240,200,74,.38)}

/* back removed */

/* ── ABOUT TEXT SIDE ── */
.about-text-side{display:flex;flex-direction:column;gap:24px;padding-top:8px}
.at-badge{display:inline-flex;align-items:center;gap:9px;background:rgba(232,0,106,.1);border:1px solid rgba(232,0,106,.3);padding:6px 16px;align-self:flex-start}
.at-badge-dot{width:6px;height:6px;border-radius:50%;background:var(--mg2);animation:bdot 1.8s ease-in-out infinite}
