.at-title em{display:block;color:var(--mg3);font-style:italic}
.at-body{font-style:italic;font-size:.94rem;color:rgba(255,178,222,.72);line-height:1.9}
/* Passions grid */
.at-passions{margin-top:8px}
.at-passion-label{font-family:var(--font-heading);font-size:.42rem;letter-spacing:.28em;text-transform:uppercase;color:var(--gold);opacity:.72;margin-bottom:14px}
.at-passion-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.at-passion{display:flex;flex-direction:column;align-items:center;gap:7px;padding:14px 8px;background:var(--dark4);border:1px solid rgba(232,0,106,.1);border-top:3px solid var(--pc);transition:background .22s,border-color .22s;cursor:default}
.at-passion:hover{background:rgba(48,12,60,.95);border-color:rgba(232,0,106,.32)}
.at-passion span{font-family:var(--font-heading);font-size:.42rem;letter-spacing:.14em;text-transform:uppercase;color:rgba(220,170,210,.65)}
.at-quote{font-family:var(--font-display);font-style:italic;font-size:1rem;color:rgba(255,178,222,.55);line-height:1.8;border-left:2px solid rgba(232,0,106,.35);padding-left:18px;margin:0}

/* ══ PAGE DECO ══ */
.page-deco{position:fixed;top:50%;left:clamp(4px,1.2vw,16px);transform:translateY(-50%);z-index:4;pointer-events:none;display:none}
@media(min-width:1400px){.page-deco{display:block}}
.deco-orbit-wrap{position:relative;width:60px;height:200px;display:flex;align-items:center;justify-content:center}
.deco-orbit{position:absolute;font-family:var(--font-display);font-size:.9rem;color:var(--mg3);animation:dorb 6s linear infinite}
.do-1{animation-delay:0s}
.do-2{animation-delay:1.5s;color:var(--gold)}
.do-3{animation-delay:3s}
.do-4{animation-delay:4.5s;color:var(--gold)}
@keyframes dorb{0%{transform:rotate(0deg) translateX(28px) rotate(0deg);opacity:.8}100%{transform:rotate(360deg) translateX(28px) rotate(-360deg);opacity:.8}}

/* ══ STORY SECTION ══ */
