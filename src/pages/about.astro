@keyframes mc-glow-pulse{0%,100%{opacity:.55;transform:scale(1)}50%{opacity:1;transform:scale(1.1)}}

/* 3D card — single face, tilt on hover */
.mc-card-3d{
  width:100%;height:100%;
  position:relative;z-index:1;
  /* Multi-layer background: deep space + rose radial + subtle scanlines */
  background:
    repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(232,0,106,.018) 3px,rgba(232,0,106,.018) 4px),
    radial-gradient(ellipse 80% 60% at 50% 30%,rgba(80,0,60,.45) 0%,transparent 70%),
    linear-gradient(160deg,#1e0830 0%,#150220 50%,#0e0118 100%);
  border:2px solid rgba(240,200,74,.5);
  border-radius:18px;overflow:hidden;
  display:flex;flex-direction:column;
  transition:box-shadow .3s;
  box-shadow:
    0 8px 32px rgba(0,0,0,.6),
    0 0 0 1px rgba(255,200,230,.08),
    inset 0 1px 0 rgba(255,200,230,.1);
}
.magical-card:hover .mc-card-3d{
  box-shadow:
    0 32px 72px rgba(0,0,0,.7),
    0 0 50px rgba(232,0,106,.5),
    0 0 100px rgba(232,0,106,.2),
    0 0 0 1px rgba(240,200,74,.2),
    inset 0 1px 0 rgba(255,200,230,.15);
}
.mc-holo{
  position:absolute;inset:0;
  background:
    linear-gradient(125deg,
      transparent 20%,
      rgba(255,220,240,.1) 38%,
      rgba(220,180,255,.14) 50%,
      rgba(255,240,160,.09) 62%,
      rgba(180,240,255,.08) 72%,
      transparent 80%);
  background-size:300% 300%;
  animation:holo-shift 5s ease-in-out infinite;
  pointer-events:none;z-index:10;border-radius:16px;
  mix-blend-mode:screen;
}
@keyframes holo-shift{
  0%{background-position:0% 0%;opacity:.6}
  33%{background-position:100% 50%;opacity:1}
  66%{background-position:50% 100%;opacity:.7}
  100%{background-position:0% 0%;opacity:.6}
}
.mc-border{position:absolute;inset:0;border:1.5px solid rgba(240,200,74,.28);border-radius:14px;pointer-events:none;z-index:11}
