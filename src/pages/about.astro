---
import Base from '../layouts/Base.astro';
---
<Base title="About — Queenny" description="Hi, I'm Queenny — the girl behind Little Confidants. A blog about manga, manhwa, anime, style and games.">

<!-- ══ HERO ══ -->
<section id="about-hero">
  <div class="ah-bg"></div>
  <div class="ah-vignette"></div>

  <!-- Animated stars background -->
  <div class="ah-stars" aria-hidden="true">
    {Array.from({length:28}).map((_,i) => (
      <div class="ah-star" style={`--x:${Math.round(5+i*3.3)}%;--y:${Math.round(8+(i*13.7)%84)}%;--s:${0.4+((i*7)%6)/10};--d:${1.8+(i*0.4)%3}s;--dl:${(i*0.3)%2.5}s`}></div>
    ))}
  </div>

  <!-- Rose window -->
  <svg class="ah-rose" viewBox="0 0 500 500" fill="none" aria-hidden="true">
    <circle cx="250" cy="250" r="242" stroke="rgba(232,0,106,.5)"  stroke-width="2"/>
    <circle cx="250" cy="250" r="190" stroke="rgba(232,0,106,.3)"  stroke-width="1.2"/>
    <circle cx="250" cy="250" r="136" stroke="rgba(140,0,180,.28)" stroke-width="1"/>
    <circle cx="250" cy="250" r="82"  stroke="rgba(232,0,106,.38)" stroke-width="1.2"/>
    <circle cx="250" cy="250" r="35"  stroke="rgba(232,0,106,.45)" stroke-width="1.2"/>
    <circle cx="250" cy="250" r="12"  fill="rgba(232,0,106,.32)"/>
    <line x1="250" y1="8"   x2="250" y2="492" stroke="rgba(232,0,106,.2)"  stroke-width=".7"/>
    <line x1="8"   y1="250" x2="492" y2="250" stroke="rgba(232,0,106,.2)"  stroke-width=".7"/>
    <line x1="44"  y1="44"  x2="456" y2="456" stroke="rgba(240,200,74,.13)" stroke-width=".5"/>
    <line x1="456" y1="44"  x2="44"  y2="456" stroke="rgba(240,200,74,.13)" stroke-width=".5"/>
    <g opacity=".38">
      {[0,45,90,135,180,225,270,315].map((deg,i)=>(
        <ellipse cx="250" cy="62" rx="12" ry="22"
          fill={i%3===0?'rgba(232,0,106,.28)':i%3===1?'rgba(240,200,74,.18)':'rgba(140,0,180,.22)'}
          transform={`rotate(${deg} 250 250)`}/>
      ))}
    </g>
  </svg>

  <!-- Gothic arch -->
  <svg class="ah-arch" viewBox="0 0 420 560" fill="none" aria-hidden="true">
    <path d="M12 560 L12 175 Q210 8 408 175 L408 560" stroke="rgba(232,0,106,.38)" stroke-width="2" fill="none"/>
    <path d="M26 560 L26 183 Q210 28 394 183 L394 560" stroke="rgba(240,200,74,.2)" stroke-width=".8" fill="none" stroke-dasharray="4 8"/>
    <circle cx="210" cy="128" r="34" fill="rgba(232,0,106,.14)" stroke="rgba(240,200,74,.42)" stroke-width="1.2"/>
    <circle cx="155" cy="160" r="25" fill="rgba(140,0,180,.1)"  stroke="rgba(240,200,74,.28)" stroke-width=".9"/>
    <circle cx="265" cy="160" r="25" fill="rgba(232,0,106,.12)" stroke="rgba(240,200,74,.28)" stroke-width=".9"/>
    <path d="M210 144 C210 144 200 138 200 132 C200 128.5 202.5 127 205.5 127 C207.5 127 210 129.5 210 129.5 C210 129.5 212.5 127 214.5 127 C217.5 127 220 128.5 220 132 C220 138 210 144 210 144Z" fill="rgba(232,0,106,.85)"/>
  </svg>

  <div class="ah-lh" style="top:18%"></div>
  <div class="ah-lh" style="bottom:22%"></div>
  <div class="ah-lv" style="left:8%"></div>
  <div class="ah-lv" style="right:8%"></div>

  <div class="ah-inner">
    <div class="ah-eyebrow"><div class="ahe-l"></div>about the blog<div class="ahe-r"></div></div>
    <h1 class="ah-title">Little Confidants</h1>
    <p class="ah-sub">A blog made with love, obsession and too many late nights reading manhwa.</p>
  </div>

  <div class="ah-scroll" aria-hidden="true">
    <div class="ah-scroll-l"></div>
    <div class="ah-scroll-t">scroll</div>
  </div>
</section>

<div class="sg-strip"><div class="sg-strip-t" id="sgstrip"></div></div>
<div class="mq"><div class="mt" id="mtrack"></div></div>

<!-- ══ MAGICAL CARD SECTION ══ -->
<div class="section-lead"></div>
<section id="about-card-section" class="glass-section">
  <div class="panel-content about-card-wrap">

    <div class="sec-head">
      <div class="sec-over"><div class="sec-rule"></div>the creator<div class="sec-rule"></div></div>
      <div class="sec-title">Meet Queenny</div>
    </div>

    <div class="card-section-layout">

      <!-- ── THE MAGICAL CARD ── -->
      <div class="magical-card-scene">
        <div class="magical-card" id="magical-card">
          <!-- 3D card — single face, no flip -->
          <div class="mc-card-3d">
              <!-- Holographic sheen overlay -->
              <div class="mc-holo"></div>
              <!-- Card border with gold corners -->
              <div class="mc-border"></div>
              <div class="mc-corner mc-corner-tl"></div>
              <div class="mc-corner mc-corner-tr"></div>
              <div class="mc-corner mc-corner-bl"></div>
              <div class="mc-corner mc-corner-br"></div>

              <!-- Top: card type + stars -->
              <div class="mc-header">
                <div class="mc-card-type">✦ Magical Girl Card ✦</div>
                <div class="mc-hp">❤ 9999 HP</div>
              </div>

              <!-- Portrait area -->
              <div class="mc-portrait-frame">
                <div class="mc-portrait-bg"></div>
                <!-- Stained glass window behind portrait -->
                <svg class="mc-portrait-window" viewBox="0 0 280 220" fill="none">
  <!-- Gothic arch -->
  <path d="M10 220 L10 90 Q140 5 270 90 L270 220Z" fill="rgba(232,0,106,.07)"/>
  <path d="M10 220 L10 92 Q140 10 270 92" fill="none" stroke="rgba(240,200,74,.5)" stroke-width="1.8"/>
  <path d="M22 220 L22 98 Q140 22 258 98" fill="none" stroke="rgba(232,0,106,.2)" stroke-width=".8" stroke-dasharray="4 7"/>
  <!-- Trefoil -->
  <circle cx="140" cy="58" r="30" fill="rgba(232,0,106,.2)" stroke="rgba(240,200,74,.55)" stroke-width="1.5"/>
  <circle cx="96"  cy="84" r="22" fill="rgba(140,0,180,.15)" stroke="rgba(240,200,74,.35)" stroke-width="1.1"/>
  <circle cx="184" cy="84" r="22" fill="rgba(232,0,106,.17)" stroke="rgba(240,200,74,.35)" stroke-width="1.1"/>
  <!-- Heart in trefoil -->
  <path d="M140 72 C140 72 131 66 131 60 C131 56.5 133.5 55 136 55 C137.8 55 140 57.5 140 57.5 C140 57.5 142.2 55 144 55 C146.5 55 149 56.5 149 60 C149 66 140 72 140 72Z" fill="rgba(255,255,255,.7)"/>
  <path d="M140 70.5 C140 70.5 133 65.5 133 60 C133 57.5 135 56 136.5 56 C138 56 140 58.5 140 58.5 C140 58.5 142 56 143.5 56 C145 56 147 57.5 147 60 C147 65.5 140 70.5 140 70.5Z" fill="rgba(232,0,106,.92)"/>
  <!-- Stained glass panels -->
  <rect x="14"  y="106" width="64" height="50" fill="rgba(232,0,106,.1)"  stroke="rgba(240,200,74,.28)" stroke-width="1"/>
  <rect x="88"  y="106" width="48" height="50" fill="rgba(140,0,180,.1)"  stroke="rgba(240,200,74,.25)" stroke-width=".9"/>
  <rect x="144" y="106" width="48" height="50" fill="rgba(232,0,106,.1)"  stroke="rgba(240,200,74,.25)" stroke-width=".9"/>
  <rect x="200" y="106" width="64" height="50" fill="rgba(240,200,74,.07)" stroke="rgba(240,200,74,.28)" stroke-width="1"/>
  <rect x="14"  y="162" width="120" height="55" fill="rgba(232,0,106,.08)" stroke="rgba(240,200,74,.22)" stroke-width=".9"/>
  <rect x="140" y="162" width="120" height="55" fill="rgba(140,0,180,.08)" stroke="rgba(240,200,74,.22)" stroke-width=".9"/>
  <!-- Lead lines -->
  <line x1="140" y1="106" x2="140" y2="218" stroke="rgba(240,200,74,.35)" stroke-width="1.3"/>
  <line x1="14"  y1="160" x2="266" y2="160" stroke="rgba(240,200,74,.28)" stroke-width="1.1"/>
  <!-- Corner gems -->
  <circle cx="10"  cy="218" r="5" fill="rgba(240,200,74,.5)"/>
  <circle cx="270" cy="218" r="5" fill="rgba(240,200,74,.5)"/>
  <!-- Extra sparkle diamonds -->
  <path d="M50 118 L53 124 L56 118 L53 112Z" fill="rgba(240,200,74,.3)"/>
  <path d="M224 118 L227 124 L230 118 L227 112Z" fill="rgba(232,0,106,.3)"/>
</svg>
                <!-- Portrait placeholder: silhouette + sparkles -->
                <div class="mc-portrait-inner">
                  <svg class="mc-silhouette" viewBox="0 0 100 130" fill="none">

  <!-- Ears: simple triangles -->
  <polygon points="22,46 14,18 38,32" fill="#1a0828"/>
  <polygon points="24,44 18,22 34,33" fill="rgba(232,0,106,.45)"/>
  <polygon points="58,46 86,18 62,32" fill="#1a0828"/>
  <polygon points="60,44 82,22 66,33" fill="rgba(232,0,106,.45)"/>

  <!-- Head: simple circle -->
  <circle cx="50" cy="54" r="28" fill="#1a0828"/>

  <!-- Moon: small crescent on forehead -->
  <circle cx="50" cy="36" r="6.5" fill="#f5d840"/>
  <circle cx="53.5" cy="34.5" r="5" fill="#1a0828"/>

  <!-- Eyes: two simple ovals + highlight -->
  <ellipse cx="39" cy="56" rx="7" ry="8.5" fill="white"/>
  <ellipse cx="39" cy="57" rx="5.5" ry="7" fill="#4a00a0"/>
  <ellipse cx="39" cy="57" rx="2" ry="6" fill="#0a0018"/>
  <circle  cx="36.5" cy="53" r="2.5" fill="white"/>

  <ellipse cx="61" cy="56" rx="7" ry="8.5" fill="white"/>
  <ellipse cx="61" cy="57" rx="5.5" ry="7" fill="#4a00a0"/>
  <ellipse cx="61" cy="57" rx="2" ry="6" fill="#0a0018"/>
  <circle  cx="58.5" cy="53" r="2.5" fill="white"/>

  <!-- Nose: tiny triangle -->
  <polygon points="50,65 47,69 53,69" fill="#ff88aa"/>

  <!-- Mouth: simple curves -->
  <path d="M45 70 Q50 74 55 70" fill="none" stroke="rgba(255,140,170,.7)" stroke-width="1.8" stroke-linecap="round"/>

  <!-- Whiskers: 3 lines each side -->
  <line x1="14" y1="62" x2="38" y2="64" stroke="rgba(255,255,255,.4)" stroke-width="1.2" stroke-linecap="round"/>
  <line x1="12" y1="67" x2="38" y2="67" stroke="rgba(255,255,255,.32)" stroke-width="1" stroke-linecap="round"/>
  <line x1="14" y1="72" x2="38" y2="70" stroke="rgba(255,255,255,.25)" stroke-width="1" stroke-linecap="round"/>
  <line x1="62" y1="64" x2="86" y2="62" stroke="rgba(255,255,255,.4)" stroke-width="1.2" stroke-linecap="round"/>
  <line x1="62" y1="67" x2="88" y2="67" stroke="rgba(255,255,255,.32)" stroke-width="1" stroke-linecap="round"/>
  <line x1="62" y1="70" x2="86" y2="72" stroke="rgba(255,255,255,.25)" stroke-width="1" stroke-linecap="round"/>

  <!-- Body: simple oval -->
  <ellipse cx="50" cy="108" rx="26" ry="22" fill="#1a0828"/>

  <!-- Bow: 3 shapes -->
  <path d="M50 90 C46 86 38 85 38 90 C38 95 48 94 50 91Z" fill="#ff4488"/>
  <path d="M50 90 C54 86 62 85 62 90 C62 95 52 94 50 91Z" fill="#ff4488"/>
  <circle cx="50" cy="90" r="4.5" fill="#ff88cc"/>
  <circle cx="49.5" cy="89.5" r="1.5" fill="rgba(255,255,255,.85)"/>

  <!-- Paws: two simple ovals -->
  <ellipse cx="34" cy="126" rx="12" ry="6" fill="#1a0828"/>
  <ellipse cx="66" cy="126" rx="12" ry="6" fill="#1a0828"/>

  <!-- Tail tip: circle -->
  <circle cx="82" cy="96" r="7" fill="#1a0828"/>
  <circle cx="82" cy="96" r="4" fill="#e8006a"/>
  <circle cx="82" cy="96" r="2" fill="rgba(255,255,255,.85)"/>
</svg>
                  <!-- Portrait sparkles -->
                  <div class="portrait-spark ps-1">✦</div>
                  <div class="portrait-spark ps-2">✧</div>
                  <div class="portrait-spark ps-3">♡</div>
                  <div class="portrait-spark ps-4">✦</div>
                </div>
              </div>

              <!-- Card name band -->
              <div class="mc-name-band">
                <div class="mc-name-inner">
                  <div class="mc-name-line"></div>
                  <div class="mc-name">Queenny</div>
                  <div class="mc-name-line"></div>
                </div>
                <div class="mc-name-sub">Magical Blog Creator</div>
              </div>

              <!-- Stats row -->
              <div class="mc-stats">
                <div class="mc-stat">
                  <div class="mc-stat-icon">📖</div>
                  <div class="mc-stat-val">999+</div>
                  <div class="mc-stat-lbl">Manhwa read</div>
                </div>
                <div class="mc-stat-div"></div>
                <div class="mc-stat">
                  <div class="mc-stat-icon">⭐</div>
                  <div class="mc-stat-val">∞</div>
                  <div class="mc-stat-lbl">Stars given</div>
                </div>
                <div class="mc-stat-div"></div>
                <div class="mc-stat">
                  <div class="mc-stat-icon">🌙</div>
                  <div class="mc-stat-val">21</div>
                  <div class="mc-stat-lbl">Years old</div>
                </div>
              </div>

              <!-- Abilities -->
              <div class="mc-abilities">
                <div class="mc-ability">
                  <span class="mc-ab-dot" style="background:var(--mg)"></span>
                  <span class="mc-ab-name">Honest reviews</span>
                  <div class="mc-ab-bar"><div class="mc-ab-fill" style="width:100%;background:var(--mg)"></div></div>
                </div>
                <div class="mc-ability">
                  <span class="mc-ab-dot" style="background:var(--gold)"></span>
                  <span class="mc-ab-name">Spoiler detection</span>
                  <div class="mc-ab-bar"><div class="mc-ab-fill" style="width:95%;background:var(--gold)"></div></div>
                </div>
                <div class="mc-ability">
                  <span class="mc-ab-dot" style="background:var(--v2)"></span>
                  <span class="mc-ab-name">Taste level</span>
                  <div class="mc-ab-bar"><div class="mc-ab-fill" style="width:98%;background:var(--v2)"></div></div>
                </div>
              </div>

              <!-- Card footer -->
              <div class="mc-footer">
                <div class="mc-footer-line"></div>
                <div class="mc-footer-txt">Little Confidants — Est. 2025</div>
                <div class="mc-footer-id">#LC-0001</div>
              </div>
          </div><!-- end mc-card-3d -->
        </div><!-- end magical-card -->
        <div class="mc-glow-wrap" aria-hidden="true">
          <div class="mc-glow-1"></div>
          <div class="mc-glow-2"></div>
        </div>
      </div><!-- end magical-card-scene -->

      <!-- ── TEXT SIDE ── -->
      <div class="about-text-side">
        <div class="at-badge">
          <div class="at-badge-dot"></div>
          <span>Hi, I'm Queenny — 21</span>
        </div>

        <h2 class="at-title">I made this blog<br/><em>because I had to.</em></h2>

        <p class="at-body">I'm 21 and I've always loved two things that people don't usually put together: stories and code. By day I build things, by night I fall into manhwa at 3am and need to tell someone about it immediately. Little Confidants is both of those things at once.</p>
        <p class="at-body">This blog is handbuilt with love — every pixel is intentional. Honest reviews, curated picks, no spoilers without warning. Just genuine enthusiasm for the things that make life better.</p>

        <div class="at-passions">
          <div class="at-passion-label">My obsessions</div>
          <div class="at-passion-grid">
            <div class="at-passion" style="--pc:var(--mg)">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="4" y="3" width="20" height="24" rx="2.5" fill="rgba(232,0,106,.2)" stroke="rgba(232,0,106,.7)" stroke-width="1.2"/><line x1="8" y1="10" x2="20" y2="10" stroke="rgba(255,160,210,.55)" stroke-width=".9"/><line x1="8" y1="14" x2="20" y2="14" stroke="rgba(255,160,210,.4)"  stroke-width=".9"/><line x1="8" y1="18" x2="15" y2="18" stroke="rgba(255,160,210,.35)" stroke-width=".9"/><path d="M4 3 L4 27 Q3 27 3 26 L3 4 Q3 3 4 3Z" fill="rgba(160,0,80,.45)"/></svg>
              <span>Manhwa</span>
            </div>
            <div class="at-passion" style="--pc:var(--gold)">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M4 24 L4 6 Q4 3.5 6.5 3.5 L21.5 3.5 Q24 3.5 24 6 L24 24 L14 20 Z" fill="rgba(240,200,74,.15)" stroke="rgba(240,200,74,.68)" stroke-width="1.2"/><line x1="8" y1="10" x2="20" y2="10" stroke="rgba(255,238,140,.35)" stroke-width=".9"/><circle cx="14" cy="16" r="2.5" fill="rgba(240,200,74,.5)"/></svg>
              <span>Manga</span>
            </div>
            <div class="at-passion" style="--pc:var(--v2)">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="3" y="8" width="22" height="14" rx="3" fill="rgba(184,64,232,.16)" stroke="rgba(184,64,232,.62)" stroke-width="1.2"/><circle cx="14" cy="15" r="4.5" fill="rgba(12,4,20,.7)" stroke="rgba(184,64,232,.4)" stroke-width=".8"/><polygon points="12,13 12,17 18,15" fill="rgba(232,0,106,.7)"/><circle cx="6" cy="10.5" r="1.8" fill="rgba(255,120,190,.7)"/></svg>
              <span>Anime</span>
            </div>
            <div class="at-passion" style="--pc:var(--t)">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 4 L16.5 11 L24 11 L18 15.5 L20.5 22.5 L14 18 L7.5 22.5 L10 15.5 L4 11 L11.5 11 Z" fill="rgba(0,200,212,.2)" stroke="rgba(0,200,212,.65)" stroke-width="1.2"/><circle cx="14" cy="14" r="3.5" fill="rgba(0,200,212,.4)"/></svg>
              <span>Style</span>
            </div>
            <div class="at-passion" style="--pc:var(--mg2)">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="3" y="9" width="22" height="13" rx="7" fill="rgba(255,68,153,.16)" stroke="rgba(255,68,153,.62)" stroke-width="1.2"/><circle cx="8" cy="15.5" r="3" fill="rgba(255,68,153,.8)" stroke="rgba(255,160,210,.55)" stroke-width=".8"/><circle cx="8" cy="15.5" r="1.3" fill="rgba(255,220,235,.85)"/><circle cx="22" cy="12.5" r="1.8" fill="rgba(232,0,106,.65)"/><circle cx="25" cy="15.5" r="1.8" fill="rgba(184,64,232,.65)"/><circle cx="22" cy="18.5" r="1.8" fill="rgba(240,200,74,.65)"/><circle cx="19" cy="15.5" r="1.8" fill="rgba(0,200,212,.65)"/></svg>
              <span>Games</span>
            </div>
            <div class="at-passion" style="--pc:rgba(255,140,200,1)">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="10" fill="rgba(255,140,200,.15)" stroke="rgba(255,140,200,.6)" stroke-width="1.2"/><path d="M10 14 L10 8 L21 13 L10 18 Z" fill="rgba(255,140,200,.7)"/></svg>
              <span>Music</span>
            </div>
            <div class="at-passion" style="--pc:rgba(100,200,255,1)">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="3" y="6" width="22" height="16" rx="3" fill="rgba(100,200,255,.12)" stroke="rgba(100,200,255,.62)" stroke-width="1.2"/><path d="M8 12 L11 15 L8 18" fill="none" stroke="rgba(100,200,255,.82)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><line x1="13" y1="18" x2="19" y2="18" stroke="rgba(100,200,255,.6)" stroke-width="1.5" stroke-linecap="round"/></svg>
              <span>Code</span>
            </div>
          </div>
        </div>

        <blockquote class="at-quote">
          "Every story is a spell — and the right one at the right time can change everything."
        </blockquote>
      </div>

    </div>
  </div>
</section>

<!-- ══ FLOATING MAGICAL ELEMENTS ══ -->
<!-- These are fixed, visible on scroll through the page -->
<div class="page-deco page-deco-l" aria-hidden="true">
  <!-- Tiny orbiting hearts -->
  <div class="deco-orbit-wrap">
    <div class="deco-orbit do-1">♡</div>
    <div class="deco-orbit do-2">✦</div>
    <div class="deco-orbit do-3">✧</div>
    <div class="deco-orbit do-4">♡</div>
  </div>
</div>

<!-- ══ BLOG STORY SECTION ══ -->
<div class="section-lead"></div>
<section id="about-story" class="glass-section">
  <div class="panel-content story-wrap">

    <!-- Left: gothic stained glass panel -->
    <div class="story-glass" aria-hidden="true">
      <svg viewBox="0 0 220 420" fill="none" width="220">
        <rect x="3" y="3" width="214" height="414" stroke="rgba(240,200,74,.48)" stroke-width="2" fill="none"/>
        <rect x="9" y="9" width="202" height="402" stroke="rgba(232,0,106,.2)" stroke-width=".8" fill="none"/>
        <path d="M3 140 Q110 3 217 140" fill="rgba(232,0,106,.1)" stroke="rgba(240,200,74,.52)" stroke-width="2"/>
        <circle cx="110" cy="82"  r="36" fill="rgba(232,0,106,.2)"  stroke="rgba(240,200,74,.52)" stroke-width="1.5"/>
        <circle cx="68"  cy="112" r="27" fill="rgba(140,0,180,.15)" stroke="rgba(240,200,74,.38)" stroke-width="1.2"/>
        <circle cx="152" cy="112" r="27" fill="rgba(232,0,106,.17)" stroke="rgba(240,200,74,.38)" stroke-width="1.2"/>
        <!-- Heart gem center -->
        <path d="M110 98 C110 98 98 90 98 82 C98 77.5 101.5 75 105.5 75 C107.8 75 110 78 110 78 C110 78 112.2 75 114.5 75 C118.5 75 122 77.5 122 82 C122 90 110 98 110 98Z" fill="rgba(255,255,255,.72)"/>
        <path d="M110 96 C110 96 100 89 100 82 C100 78.5 103 77 105.5 77 C107.5 77 110 80 110 80 C110 80 112.5 77 114.5 77 C117 77 120 78.5 120 82 C120 89 110 96 110 96Z" fill="rgba(232,0,106,.88)"/>
        <path d="M103 78.5 C102.5 80 102.2 82 103 84" stroke="rgba(255,255,255,.6)" stroke-width="1.8" stroke-linecap="round"/>
