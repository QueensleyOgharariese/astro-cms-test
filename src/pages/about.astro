.sc-twitter{border-top-color:rgba(29,161,242,.55)}
.sc-instagram{border-top-color:rgba(225,48,108,.55)}
.sc-tiktok{border-top-color:rgba(254,44,85,.55)}
.sc-pinterest{border-top-color:rgba(230,0,35,.55)}
