---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'Manga, manhwa, anime, style and music — honest reviews and curated picks.', image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
  <title>{title} — Little Confidants</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={`${title} — Little Confidants`} />
  <meta property="og:description" content={description} />
  {image && <meta property="og:image" content={image} />}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} — Little Confidants`} />
  <meta name="twitter:description" content={description} />

  <!-- Netlify Identity (for CMS) -->
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>

<!-- Cursor -->
<div id="cur"></div>
<div id="cur-r"></div>
<canvas id="trail-canvas"></canvas>
<canvas id="stars-canvas"></canvas>

<!-- Stained glass bg -->
<div id="sg-bg">
  <svg viewBox="0 0 100 100" preserveAspectRatio="xMidYMid slice"> <defs> <pattern id="p1" x="0" y="0" width="14" height="14" patternUnits="userSpaceOnUse"> <polygon points="7,0 14,7 7,14 0,7" fill="none" stroke="rgba(224,0,154,1)" stroke-width=".22"/> </pattern> <pattern id="p2" x="0" y="0" width="28" height="28" patternUnits="userSpaceOnUse"> <polygon points="14,0 28,14 14,28 0,14" fill="none" stroke="rgba(240,200,74,.75)" stroke-width=".18"/> <circle cx="14" cy="14" r="2.5" fill="none" stroke="rgba(224,0,154,.55)" stroke-width=".18"/> </pattern> </defs> <rect width="100" height="100" fill="url(#p1)"/> <rect width="100" height="100" fill="url(#p2)"/> </svg>
</div>
<div id="beams"></div>

<!-- NAVBAR -->

<!-- ══ MAGICAL TRANSFORMATION LOADER ══ -->
<div id="mg-loader" aria-hidden="true">
  <div class="mgl-bg"></div>

  <!-- Transformation circle rings -->
  <div class="mgl-rings">
    <div class="mgl-ring mgl-ring-1"></div>
    <div class="mgl-ring mgl-ring-2"></div>
    <div class="mgl-ring mgl-ring-3"></div>
  </div>

  <!-- Center: cat silhouette + moon -->
  <div class="mgl-center">
    <svg class="mgl-cat" viewBox="0 0 80 100" fill="none">
  <!-- Long ears -->
  <rect x="22" y="2" width="11" height="36" rx="5.5" fill="#1a0828"/>
  <rect x="25" y="5" width="5" height="28" rx="2.5" fill="rgba(232,0,106,.5)"/>
  <rect x="47" y="2" width="11" height="36" rx="5.5" fill="#1a0828"/>
  <rect x="50" y="5" width="5" height="28" rx="2.5" fill="rgba(232,0,106,.5)"/>
  <!-- Head -->
  <circle cx="40" cy="50" r="22" fill="#1a0828"/>
  <!-- Crescent moon forehead — small -->
  <circle cx="40" cy="35" r="5" fill="#f5d840"/>
  <circle cx="43" cy="33.5" r="3.8" fill="#1a0828"/>
  <!-- Eyes closed — two curved lines -->
  <path d="M29 51 Q32 47 35 51" fill="none" stroke="rgba(255,255,255,.85)" stroke-width="2.5" stroke-linecap="round"/>
  <path d="M45 51 Q48 47 51 51" fill="none" stroke="rgba(255,255,255,.85)" stroke-width="2.5" stroke-linecap="round"/>
  <!-- Nose: tiny dot -->
  <circle cx="40" cy="57" r="2" fill="rgba(255,140,180,.8)"/>
  <!-- Body -->
  <ellipse cx="40" cy="82" rx="20" ry="16" fill="#1a0828"/>
  <!-- Bow -->
  <path d="M40 68 C36 64 29 64 29 68 C29 72 38 71 40 69Z" fill="#e8006a"/>
  <path d="M40 68 C44 64 51 64 51 68 C51 72 42 71 40 69Z" fill="#e8006a"/>
  <circle cx="40" cy="68" r="4" fill="#ff88cc"/>
  <!-- Tail: small white circle -->
  <circle cx="58" cy="80" r="5" fill="rgba(255,255,255,.2)"/>
  <circle cx="58" cy="80" r="3" fill="rgba(255,255,255,.35)"/>
</svg>

    <!-- Orbiting stars during load -->
    <div class="mgl-orbit-wrap">
      <div class="mgl-orb" style="--or:70px;--od:1.8s;--odl:0s">✦</div>
      <div class="mgl-orb" style="--or:70px;--od:1.8s;--odl:-.6s">✧</div>
      <div class="mgl-orb" style="--or:70px;--od:1.8s;--odl:-1.2s">♡</div>
      <div class="mgl-orb" style="--or:100px;--od:2.8s;--odl:0s">✦</div>
      <div class="mgl-orb" style="--or:100px;--od:2.8s;--odl:-.93s">✦</div>
      <div class="mgl-orb" style="--or:100px;--od:2.8s;--odl:-1.87s">✦</div>
    </div>
  </div>

  <!-- Blog name reveal -->
  <div class="mgl-title">Little Confidants</div>
  <div class="mgl-sub">✦ loading magic ✦</div>
</div>

<nav id="nav">
  <a class="logo" href="/">
    <!-- Wand tip logo: 8-point star with heart core -->
    <svg class="logo-rose" width="38" height="38" viewBox="0 0 80 80" fill="none"> <defs> <radialGradient id="logo-glow" cx="50%" cy="50%" r="50%"> <stop offset="0%" stop-color="rgba(255,255,255,.9)"/> <stop offset="100%" stop-color="rgba(224,0,154,0)"/> </radialGradient> </defs> <ellipse cx="40" cy="40" rx="36" ry="36" fill="url(#logo-glow)" opacity=".5"/> <path d="M40 4 L44 18 L56 12 L51 24 L65 26 L55 34 L61 47 L48 43 L47 57 L40 46 L33 57 L32 43 L19 47 L25 34 L15 26 L29 24 L24 12 L36 18 Z" fill="rgba(255,220,245,.88)" stroke="rgba(224,0,154,.65)" stroke-width="1"/> <path d="M40 16 L43 25 L52 25 L45 31 L48 40 L40 34 L32 40 L35 31 L28 25 L37 25 Z" fill="rgba(224,0,154,.6)" stroke="rgba(255,180,232,.5)" stroke-width=".8"/> <path d="M40 39 C40 39 31 33 31 27 C31 23.5 33.5 21 37 21 C38.5 21 40 22.5 40 22.5 C40 22.5 41.5 21 43 21 C46.5 21 49 23.5 49 27 C49 33 40 39 40 39Z" fill="rgba(255,255,255,.88)"/> <path d="M40 37 C40 37 32.5 32 32.5 27 C32.5 24 34.5 22 37 22 C38.5 22 40 23.5 40 25.5 C40 23.5 41.5 22 43 22 C45.5 22 47.5 24 47.5 27 C47.5 32 40 37 40 37Z" fill="rgba(224,0,154,.85)"/> <path d="M34.5 23.5 C34.5 23.5 33 25 33 27.5" stroke="rgba(255,255,255,.55)" stroke-width="1.2" stroke-linecap="round" fill="none"/> <ellipse cx="40" cy="58" rx="10" ry="3.5" fill="rgba(240,200,74,.7)" stroke="rgba(255,230,120,.8)" stroke-width="1"/> <circle cx="40" cy="58" r="2" fill="rgba(240,200,74,1)"/> <rect x="37" y="60" width="6" height="16" rx="3" fill="rgba(224,0,154,.7)"/> <line x1="40" y1="1" x2="40" y2="8" stroke="rgba(255,240,252,.85)" stroke-width="1.5" stroke-linecap="round"/> <line x1="64" y1="10" x2="59" y2="15" stroke="rgba(255,240,252,.65)" stroke-width="1.2" stroke-linecap="round"/> <line x1="16" y1="10" x2="21" y2="15" stroke="rgba(255,240,252,.65)" stroke-width="1.2" stroke-linecap="round"/> </svg>
    <div class="logo-t">
      Little Confidants
      <span class="logo-s">manga · manhwa · anime · style</span>
    </div>
  </a>

  <div class="nav-links">
    <a class="nav-a" href="/">Home</a>
    <a class="nav-a" href="/blog">Blog</a>
    <a class="nav-a" href="/recs">Favorites</a>
    <a class="nav-cta" href="/about"><span>About</span></a>
  </div>

  <!-- Hamburger for mobile -->
  <button class="nav-hamburger" id="nav-toggle" aria-label="Toggle menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- Mobile menu -->
<div class="mobile-menu" id="mobile-menu">
  <a href="/" class="mobile-link">Home</a>
  <a href="/blog" class="mobile-link">Blog</a>
  <a href="/recs" class="mobile-link">Favorites</a>
  <a href="/about" class="mobile-link mobile-link-cta">About</a>
</div>

<main>
  <slot />
</main>

<!-- FOOTER -->
<footer id="site-footer">
  <div class="footer-top">
    <div class="footer-rule"></div>
    <div class="footer-mid">— Little Confidants —</div>
    <div class="footer-rule footer-rule-r"></div>
  </div>
  <div class="footer-bot">
    <div class="footer-brand">Little Confidants</div>
    <nav class="footer-links">
      <a href="/about" class="footer-link">About</a>
      <a href="/blog" class="footer-link">Blog</a>
      <a href="/recs" class="footer-link">Recs</a>
      <a href="/rss.xml" class="footer-link">RSS</a>
    </nav>
  </div>
</footer>

<style>#nav{position:fixed;top:0;left:0;right:0;z-index:2000;height:66px;padding:0 52px;display:flex;align-items:center;justify-content:space-between;background:rgba(26,8,32,.88);backdrop-filter:blur(28px);border-bottom:2px solid rgba(232,0,106,.25);transition:background .4s}#nav::after{content:'';position:absolute;bottom:-1px;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--gold),var(--mg2),var(--gold),transparent);animation:nline 3.5s ease-in-out infinite}@keyframes nline{0%,100%{opacity:.55}50%{opacity:1}}#nav.scrolled{background:rgba(26,8,32,.98) !important;border-color:rgba(255,120,190,.78)}.logo{display:flex;align-items:center;gap:10px;cursor:pointer;text-decoration:none}.logo-rose{width:38px;height:38px;flex-shrink:0;animation:logo-float 4s ease-in-out infinite;filter:drop-shadow(0 0 8px rgba(224,0,154,.6))}@keyframes logo-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-3px)}}.logo-t{font-family:var(--font-display);font-size:1.1rem;font-weight:600;font-style:italic;color:var(--mg5);letter-spacing:.08em}.logo-s{font-size:.43rem;font-weight:300;font-style:normal;letter-spacing:.3em;text-transform:uppercase;color:rgba(255,120,190,.78);display:block;margin-top:1px}.nav-links{display:flex;align-items:center}.nav-a{font-family:var(--font-heading);font-size:.5rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(240,220,245,.62);padding:10px 15px;cursor:pointer;transition:color .22s;position:relative;text-decoration:none}.nav-a::after{content:'';position:absolute;bottom:6px;left:15px;right:15px;height:1px;background:linear-gradient(90deg,var(--mg),var(--gold));transform:scaleX(0);transform-origin:left;transition:transform .3s cubic-bezier(.77,0,.175,1)}.nav-a:hover{color:var(--mg4)}.nav-a:hover::after{transform:scaleX(1)}.nav-a[aria-current="page"]{color:var(--mg4)}.nav-a[aria-current="page"]::after{transform:scaleX(1)}.nav-cta{font-family:var(--font-heading);font-size:.48rem;letter-spacing:.18em;text-transform:uppercase;padding:9px 22px;margin-left:10px;cursor:pointer;background:rgba(224,0,154,.16);border:1px solid rgba(255,120,190,.78);color:var(--mg4);transition:all .3s;position:relative;overflow:hidden;text-decoration:none}.nav-cta::before{content:'';position:absolute;inset:0;background:var(--mg);transform:translateX(-100%);transition:transform .3s cubic-bezier(.77,0,.175,1)}.nav-cta:hover::before{transform:translateX(0)}.nav-cta:hover{color:var(--dark)}.nav-cta span{position:relative;z-index:1}.nav-hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:5px}.nav-hamburger span{display:block;width:24px;height:1.5px;background:rgba(255,160,232,.7);transition:all .3s}.mobile-menu{display:none;position:fixed;top:66px;left:0;right:0;z-index:1999;background:rgba(26,8,32,.98);backdrop-filter:blur(28px);border-bottom:2px solid rgba(224,0,154,.3);flex-direction:column;padding:20px 32px 28px}.mobile-menu.open{display:flex}.mobile-link{font-family:var(--font-heading);font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(240,224,248,.5);padding:12px 0;border-bottom:1px solid rgba(224,0,154,.1);text-decoration:none;transition:color .2s}.mobile-link:hover{color:var(--mg4)}.mobile-link-cta{color:var(--mg3);border-bottom:none;margin-top:8px}main{position:relative;z-index:5;padding-top:66px}#mg-loader{position:fixed;inset:0;z-index:99999;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;background:var(--dark);transition:opacity .6s ease,visibility .6s ease}#mg-loader.mgl-hidden{opacity:0;visibility:hidden;pointer-events:none}.mgl-bg{position:absolute;inset:0;background:radial-gradient(ellipse 60% 60% at 50% 50%,rgba(232,0,106,.18) 0%,rgba(100,0,140,.1) 40%,transparent 70%);animation:mgl-pulse 2s ease-in-out infinite}@keyframes mgl-pulse{0%,100%{opacity:.6}50%{opacity:1}}.mgl-rings{position:absolute;inset:0;pointer-events:none}.mgl-ring{position:absolute;top:50%;left:50%;border-radius:50%;border:1px solid;animation:mgl-ring-expand 2s ease-out infinite}.mgl-ring-1{width:160px;height:160px;margin:-80px 0 0 -80px;border-color:rgba(232,0,106,.55);animation-delay:0s}.mgl-ring-2{width:240px;height:240px;margin:-120px 0 0 -120px;border-color:rgba(240,200,74,.38);animation-delay:.4s}.mgl-ring-3{width:320px;height:320px;margin:-160px 0 0 -160px;border-color:rgba(180,60,230,.28);animation-delay:.8s}@keyframes mgl-ring-expand{0%{transform:scale(.6);opacity:0}40%{opacity:1}100%{transform:scale(1.4);opacity:0}}.mgl-center{position:relative;z-index:2;display:flex;align-items:center;justify-content:center}.mgl-cat{width:110px;height:auto;animation:mgl-cat-float 2s ease-in-out infinite;filter:drop-shadow(0 0 18px rgba(232,0,106,.7)) drop-shadow(0 0 36px rgba(232,0,106,.3))}@keyframes mgl-cat-float{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-10px) scale(1.04)}}.mgl-title{font-family:var(--font-display);font-size:clamp(1.6rem,4vw,2.4rem);font-weight:300;font-style:italic;background:linear-gradient(135deg,var(--mg5),var(--mg3),var(--gold2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;position:relative;z-index:2;animation:mgl-fadein 1s ease .3s both}.mgl-sub{font-family:var(--font-heading);font-size:.44rem;letter-spacing:.42em;text-transform:uppercase;color:var(--gold);opacity:.7;position:relative;z-index:2;animation:mgl-fadein 1s ease .6s both}@keyframes mgl-fadein{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}@media (max-width:860px){#nav{padding:0 20px}.nav-links{display:none}.nav-hamburger{display:flex}.logo-s{display:none}.logo-t{font-size:1rem}}@media (max-width:480px){#nav{padding:0 14px;height:58px}.logo-rose{width:30px;height:30px}.logo-t{font-size:.9rem}main{padding-top:58px}}</style>

<script>

/* ── MAGICAL LOADER ── */
(function(){
  const loader = document.getElementById('mg-loader');
  if(!loader) return;
  function hideLoader(){
    loader.classList.add('mgl-hidden');
    setTimeout(()=>{ loader.style.display='none'; }, 700);
  }
  // Hide after load, min 1.2s to see the animation
  const t = Date.now();
  window.addEventListener('load', ()=>{
    const elapsed = Date.now() - t;
    const wait = Math.max(0, 1200 - elapsed);
    setTimeout(hideLoader, wait);
  });
  // Fallback: always hide after 3s
  setTimeout(hideLoader, 3000);
})();

/* ── CURSOR TRAIL ── */
const trailCvs = document.getElementById('trail-canvas') as HTMLCanvasElement;
const tc = trailCvs.getContext('2d')!;
let W = window.innerWidth, H = window.innerHeight;
trailCvs.width = W; trailCvs.height = H;
window.addEventListener('resize', () => { W = window.innerWidth; H = window.innerHeight; trailCvs.width = W; trailCvs.height = H; });

const trail: any[] = [];
let mx = W/2, my = H/2, rx = mx, ry = my;

document.addEventListener('mousemove', e => {
  mx = e.clientX; my = e.clientY;
  for (let i = 0; i < 3; i++) {
    trail.push({ x: mx+(Math.random()-.5)*8, y: my+(Math.random()-.5)*8, r: 1.5+Math.random()*3, life: 1, decay: .045+Math.random()*.035, vx: (Math.random()-.5)*.8, vy: (Math.random()-.5)*.8-.5, hue: Math.random()>.5?315:280, isStar: Math.random()>.7 });
  }
  if (trail.length > 80) trail.splice(0, trail.length - 80);
  document.getElementById('cur')!.style.left = mx + 'px';
  document.getElementById('cur')!.style.top = my + 'px';
});

function drawStar(cx:number,cy:number,r:number,col:string,a:number) {
  tc.save(); tc.globalAlpha=a; tc.fillStyle=col; tc.translate(cx,cy); tc.beginPath();
  for(let i=0;i<5;i++){const a1=-Math.PI/2+(i*4*Math.PI/5),a2=-Math.PI/2+((i*4+2)*Math.PI/5);tc.lineTo(Math.cos(a1)*r,Math.sin(a1)*r);tc.lineTo(Math.cos(a2)*r*.42,Math.sin(a2)*r*.42);}
  tc.closePath(); tc.fill(); tc.restore();
}

(function animTrail() {
  tc.clearRect(0,0,W,H);
  for(let i=trail.length-1;i>=0;i--){
    const p=trail[i]; p.x+=p.vx; p.y+=p.vy; p.vy+=.015; p.life-=p.decay;
    if(p.life<=0){trail.splice(i,1);continue;}
    const col=`hsl(${p.hue},100%,65%)`;
    if(p.isStar){drawStar(p.x,p.y,p.r*1.4,col,p.life*.85);}
    else{tc.save();tc.globalAlpha=p.life*.8;tc.fillStyle=col;tc.shadowColor=col;tc.shadowBlur=p.r*3;tc.beginPath();tc.arc(p.x,p.y,p.r,0,Math.PI*2);tc.fill();tc.restore();}
  }
  requestAnimationFrame(animTrail);
})();

/* Ring follow */
const ring = document.getElementById('cur-r')!;
(function loopRing(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(loopRing);})();
document.querySelectorAll('a,button,.btn,.post-card,.cat,.tag-pill').forEach(el=>{
  el.addEventListener('mouseenter',()=>{ring.style.width='46px';ring.style.height='46px';ring.style.borderColor='rgba(255,0,200,.72)';});
  el.addEventListener('mouseleave',()=>{ring.style.width='34px';ring.style.height='34px';ring.style.borderColor='rgba(255,0,200,.3)';});
});

/* ── FALLING STARS ── */
const stcvs = document.getElementById('stars-canvas') as HTMLCanvasElement;
const stc = stcvs.getContext('2d')!;
stcvs.width = window.innerWidth; stcvs.height = window.innerHeight;
window.addEventListener('resize', () => { stcvs.width = window.innerWidth; stcvs.height = window.innerHeight; });
const shootingStars: any[] = [];
function spawnStar(){
  const side = Math.random()>.5?'top':'left';
  shootingStars.push({ x:side==='top'?Math.random()*window.innerWidth:-20, y:side==='top'?-20:Math.random()*window.innerHeight*.5, len:60+Math.random()*120, speed:3+Math.random()*5, angle:Math.PI*.18+Math.random()*.2, life:1, decay:.012+Math.random()*.008, width:1+Math.random()*1.5, hue:Math.random()>.5?315:260 });
}
setInterval(spawnStar, 800);
const staticStars = Array.from({length:120},()=>({x:Math.random()*window.innerWidth,y:Math.random()*window.innerHeight,r:.5+Math.random()*1.5,a:.1+Math.random()*.5,speed:.5+Math.random()*1.5,phase:Math.random()*Math.PI*2,hue:Math.random()>.5?315:260}));
(function animStars(){
  stc.clearRect(0,0,stcvs.width,stcvs.height);
  const t=Date.now()*.001;
  staticStars.forEach(s=>{
    const a=s.a*(0.4+0.6*Math.abs(Math.sin(t*s.speed+s.phase)));
    stc.save();stc.globalAlpha=a;stc.fillStyle=`hsl(${s.hue},80%,80%)`;stc.shadowColor=`hsl(${s.hue},100%,70%)`;stc.shadowBlur=s.r*3;stc.beginPath();stc.arc(s.x,s.y,s.r,0,Math.PI*2);stc.fill();stc.restore();
  });
  for(let i=shootingStars.length-1;i>=0;i--){
    const s=shootingStars[i]; s.x+=Math.cos(s.angle)*s.speed; s.y+=Math.sin(s.angle)*s.speed; s.life-=s.decay;
    if(s.life<=0||s.x>stcvs.width+50||s.y>stcvs.height+50){shootingStars.splice(i,1);continue;}
    const tx=s.x-Math.cos(s.angle)*s.len, ty=s.y-Math.sin(s.angle)*s.len;
    const grad=stc.createLinearGradient(tx,ty,s.x,s.y);
    grad.addColorStop(0,'rgba(0,0,0,0)');grad.addColorStop(.7,`hsla(${s.hue},100%,80%,${s.life*.6})`);grad.addColorStop(1,`hsla(${s.hue},100%,90%,${s.life})`);
    stc.save();stc.globalAlpha=s.life;stc.strokeStyle=grad;stc.lineWidth=s.width;stc.shadowColor=`hsl(${s.hue},100%,75%)`;stc.shadowBlur=8;stc.beginPath();stc.moveTo(tx,ty);stc.lineTo(s.x,s.y);stc.stroke();
    stc.fillStyle=`hsla(${s.hue},100%,95%,${s.life})`;stc.shadowBlur=12;stc.beginPath();stc.arc(s.x,s.y,s.width*1.2,0,Math.PI*2);stc.fill();stc.restore();
  }
  requestAnimationFrame(animStars);
})();

/* ── BEAMS ── */
const beamsEl = document.getElementById('beams')!;
[{l:4,w:3,h:68,d:8,dl:0,r1:'-3deg',r2:'3deg',g:false},{l:17,w:2,h:55,d:11,dl:-2,r1:'-4deg',r2:'2deg',g:true},{l:29,w:4,h:73,d:9,dl:-4,r1:'2deg',r2:'-2deg',g:false},{l:44,w:2,h:58,d:13,dl:-6,r1:'-2deg',r2:'4deg',g:false},{l:57,w:3,h:68,d:8.5,dl:-1,r1:'3deg',r2:'-3deg',g:true},{l:69,w:2,h:56,d:12,dl:-3,r1:'-4deg',r2:'2deg',g:false},{l:81,w:4,h:70,d:9.5,dl:-5,r1:'2deg',r2:'-4deg',g:false},{l:91,w:2,h:60,d:11,dl:-7,r1:'-2deg',r2:'3deg',g:true}].forEach(b=>{
  const el=document.createElement('div'); el.className='beam';
  const bg=b.g?'linear-gradient(180deg,rgba(240,200,74,0) 0%,rgba(240,200,74,.06) 30%,rgba(240,200,74,.1) 60%,rgba(240,200,74,0) 100%)':'linear-gradient(180deg,rgba(224,0,154,0) 0%,rgba(224,0,154,.08) 25%,rgba(224,0,154,.13) 55%,rgba(224,0,154,0) 100%)';
  el.style.cssText=`left:${b.l}%;width:${b.w}px;height:${b.h}%;background:${bg};--d:${b.d}s;--dl:${b.dl}s;--r1:${b.r1};--r2:${b.r2}`;
  beamsEl.appendChild(el);
});

/* ── MARQUEE ── */
const items=['Romance Manhwa','Shojo Manga','Otome Games','My Recommendations','Honest Reviews','Best of 2025','Top Romances','Manhwa Recs','Discussion','Little Confidants'];
const mtrack = document.getElementById('mtrack');
if(mtrack){[...items,...items].forEach(t=>{const d=document.createElement('div');d.className='mi';d.innerHTML=t+'<span class="mgm"></span>';mtrack.appendChild(d);});}

/* ── STAINED GLASS STRIP ── */
const stripEl = document.getElementById('sgstrip');
if(stripEl){
  const colors=['rgba(224,0,154,.52)','rgba(240,200,74,.48)','rgba(144,0,200,.42)','rgba(0,200,212,.36)','rgba(224,0,154,.58)'];
  const w=Math.max(window.innerWidth*2,1600), cols=Math.ceil(w/16)+2;
  let svg=`<svg width="${w}" height="44" viewBox="0 0 ${w} 44" fill="none">`;
  for(let i=0;i<cols;i++){const x=i*16;svg+=`<polygon points="${x+8},0 ${x+16},22 ${x+8},44 ${x},22" fill="${colors[i%colors.length]}" stroke="rgba(14,8,32,1)" stroke-width="1.5"/>`;}
  svg+='</svg>'; stripEl.innerHTML=svg+svg;
}

/* ── NAV SCROLL + ACTIVE ── */
window.addEventListener('scroll',()=>document.getElementById('nav')!.classList.toggle('scrolled',window.scrollY>55));

/* ── MOBILE MENU ── */
document.getElementById('nav-toggle')?.addEventListener('click',()=>{document.getElementById('mobile-menu')!.classList.toggle('open');});

/* (panel reveal removed) */

/* ── NETLIFY IDENTITY ── */
if((window as any).netlifyIdentity){
  (window as any).netlifyIdentity.on('init', (user:any) => {
    if(!user){(window as any).netlifyIdentity.on('login',()=>{document.location.href='/admin/';})}
  });
}
</script>
