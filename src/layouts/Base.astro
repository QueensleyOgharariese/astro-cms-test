---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'Manga, manhwa, anime, style and music — honest reviews and curated picks.', image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
  <title>{title} — Little Confidants</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {image && <meta property="og:image" content={image} />}
</head>
<body>

<!-- Cursor -->
<div id="cur"></div>
<div id="cur-r"></div>
<canvas id="trail-canvas"></canvas>
<canvas id="stars-canvas"></canvas>

<!-- Stained glass bg -->
<div id="sg-bg">
  <svg viewBox="0 0 100 100" preserveAspectRatio="xMidYMid slice">
    <defs>
      <pattern id="p1" x="0" y="0" width="14" height="14" patternUnits="userSpaceOnUse">
        <polygon points="7,0 14,7 7,14 0,7" fill="none" stroke="rgba(224,0,154,1)" stroke-width=".22"/>
      </pattern>
      <pattern id="p2" x="0" y="0" width="28" height="28" patternUnits="userSpaceOnUse">
        <polygon points="14,0 28,14 14,28 0,14" fill="none" stroke="rgba(240,200,74,.75)" stroke-width=".18"/>
        <circle cx="14" cy="14" r="2.5" fill="none" stroke="rgba(224,0,154,.55)" stroke-width=".18"/>
      </pattern>
    </defs>
    <rect width="100" height="100" fill="url(#p1)"/>
    <rect width="100" height="100" fill="url(#p2)"/>
  </svg>
</div>
<div id="beams"></div>

<!-- NAVBAR -->
<nav id="nav">
  <a class="logo" href="/">
    <svg class="logo-rose" width="38" height="38" viewBox="0 0 80 80" fill="none"> ... </svg>
    <div class="logo-t">
      Little Confidants
      <span class="logo-s">manga · manhwa · anime · style</span>
    </div>
  </a>

  <div class="nav-links">
    <a class="nav-a" href="/">Home</a>
    <a class="nav-a" href="/blog">Blog</a>
    <a class="nav-a" href="/recs">Favorites</a>
    <a class="nav-cta" href="/about"><span>About</span></a>
  </div>

  <button class="nav-hamburger" id="nav-toggle" aria-label="Toggle menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="mobile-menu" id="mobile-menu">
  <a href="/" class="mobile-link">Home</a>
  <a href="/blog" class="mobile-link">Blog</a>
  <a href="/recs" class="mobile-link">Favorites</a>
  <a href="/about" class="mobile-link mobile-link-cta">About</a>
</div>

<main>
  <slot />
</main>

<!-- FOOTER -->
<footer id="site-footer">
  <div class="footer-top">
    <div class="footer-rule"></div>
    <div class="footer-mid">— Little Confidants —</div>
    <div class="footer-rule footer-rule-r"></div>
  </div>
  <div class="footer-bot">
    <div class="footer-brand">Little Confidants</div>
    <nav class="footer-links">
      <a href="/about" class="footer-link">About</a>
      <a href="/blog" class="footer-link">Blog</a>
      <a href="/recs" class="footer-link">Recs</a>
      <a href="/rss.xml" class="footer-link">RSS</a>
    </nav>
  </div>
</footer>

<style>
/* ── NAVBAR ── */
#nav{position:fixed;top:0;left:0;right:0;z-index:2000;height:66px;padding:0 52px;display:flex;align-items:center;justify-content:space-between;background:rgba(26,8,32,.88);backdrop-filter:blur(28px);border-bottom:2px solid rgba(232,0,106,.25);transition:background .4s}
#nav::after{content:'';position:absolute;bottom:-1px;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--gold),var(--mg2),var(--gold),transparent);animation:nline 3.5s ease-in-out infinite}
@keyframes nline{0%,100%{opacity:.55}50%{opacity:1}}
#nav.scrolled{background:rgba(26,8,32,.98) !important;border-color:rgba(255,120,190,.78)}
.logo{display:flex;align-items:center;gap:10px;cursor:pointer;text-decoration:none}
.logo-rose{width:38px;height:38px;flex-shrink:0;animation:logo-float 4s ease-in-out infinite;filter:drop-shadow(0 0 8px rgba(224,0,154,.6))}
@keyframes logo-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-3px)}}
.logo-t{font-family:var(--font-display);font-size:1.1rem;font-weight:600;font-style:italic;color:var(--mg5);letter-spacing:.08em}
.logo-s{font-size:.43rem;font-weight:300;font-style:normal;letter-spacing:.3em;text-transform:uppercase;color:rgba(255,120,190,.78);display:block;margin-top:1px}
.nav-links{display:flex;align-items:center}
.nav-a{font-family:var(--font-heading);font-size:.5rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(240,220,245,.62);padding:10px 15px;cursor:pointer;transition:color .22s;position:relative;text-decoration:none}
.nav-a::after{content:'';position:absolute;bottom:6px;left:15px;right:15px;height:1px;background:linear-gradient(90deg,var(--mg),var(--gold));transform:scaleX(0);transform-origin:left;transition:transform .3s cubic-bezier(.77,0,.175,1)}
.nav-a:hover{color:var(--mg4)}
.nav-a:hover::after{transform:scaleX(1)}
.nav-a[aria-current="page"]{color:var(--mg4)}
.nav-a[aria-current="page"]::after{transform:scaleX(1)}
.nav-cta{font-family:var(--font-heading);font-size:.48rem;letter-spacing:.18em;text-transform:uppercase;padding:9px 22px;margin-left:10px;cursor:pointer;background:rgba(224,0,154,.16);border:1px solid rgba(255,120,190,.78);color:var(--mg4);transition:all .3s;position:relative;overflow:hidden;text-decoration:none}
.nav-cta::before{content:'';position:absolute;inset:0;background:var(--mg);transform:translateX(-100%);transition:transform .3s cubic-bezier(.77,0,.175,1)}
.nav-cta:hover::before{transform:translateX(0)}
.nav-cta:hover{color:var(--dark)}
.nav-cta span{position:relative;z-index:1}
.nav-hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:5px}
.nav-hamburger span{display:block;width:24px;height:1.5px;background:rgba(255,160,232,.7);transition:all .3s}
.mobile-menu{display:none;position:fixed;top:66px;left:0;right:0;z-index:1999;background:rgba(26,8,32,.98);backdrop-filter:blur(28px);border-bottom:2px solid rgba(224,0,154,.3);flex-direction:column;padding:20px 32px 28px}
.mobile-menu.open{display:flex}
.mobile-link{font-family:var(--font-heading);font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(240,224,248,.5);padding:12px 0;border-bottom:1px solid rgba(224,0,154,.1);text-decoration:none;transition:color .2s}
.mobile-link:hover{color:var(--mg4)}
.mobile-link-cta{color:var(--mg3);border-bottom:none;margin-top:8px}
main{position:relative;z-index:5;padding-top:66px}

/* ── CURSOR TRAIL ── */
#cur, #cur-r{position:fixed;top:0;left:0;width:16px;height:16px;border-radius:50%;pointer-events:none;z-index:9999}
#cur{background:rgba(255,0,200,.7);transform:translate(-50%,-50%) scale(0.5)}
#cur-r{border:2px solid rgba(255,0,200,.3);transform:translate(-50%,-50%)}

/* ── BEAMS, STARS e altri effetti visivi rimangono identici al tuo JS originale */
</style>

<script type="module">
/* ── CURSOR TRAIL ── */
const trailCvs = document.getElementById('trail-canvas');
const tc = trailCvs.getContext('2d');
let W = window.innerWidth, H = window.innerHeight;
trailCvs.width = W; trailCvs.height = H;
window.addEventListener('resize', () => { W = window.innerWidth; H = window.innerHeight; trailCvs.width = W; trailCvs.height = H; });

const trail = [];
let mx = W/2, my = H/2, rx = mx, ry = my;

document.addEventListener('mousemove', e => {
  mx = e.clientX; my = e.clientY;
  for (let i = 0; i < 3; i++) {
    trail.push({ x: mx+(Math.random()-.5)*8, y: my+(Math.random()-.5)*8, r: 1.5+Math.random()*3, life: 1, decay: .045+Math.random()*.035, vx: (Math.random()-.5)*.8, vy: (Math.random()-.5)*.8-.5, hue: Math.random()>.5?315:280, isStar: Math.random()>.7 });
  }
  if (trail.length > 80) trail.splice(0, trail.length - 80);
  document.getElementById('cur').style.left = mx + 'px';
  document.getElementById('cur').style.top = my + 'px';
});

function drawStar(cx,cy,r,col,a){
  tc.save(); tc.globalAlpha=a; tc.fillStyle=col; tc.translate(cx,cy); tc.beginPath();
  for(let i=0;i<5;i++){const a1=-Math.PI/2+(i*4*Math.PI/5),a2=-Math.PI/2+((i*4+2)*Math.PI/5);tc.lineTo(Math.cos(a1)*r,Math.sin(a1)*r);tc.lineTo(Math.cos(a2)*r*.42,Math.sin(a2)*r*.42);}
  tc.closePath(); tc.fill(); tc.restore();
}

(function animTrail(){
  tc.clearRect(0,0,W,H);
  for(let i=trail.length-1;i>=0;i--){
    const p=trail[i]; p.x+=p.vx; p.y+=p.vy; p.vy+=.015; p.life-=p.decay;
    if(p.life<=0){trail.splice(i,1);continue;}
    const col=`hsl(${p.hue},100%,65%)`;
    if(p.isStar){drawStar(p.x,p.y,p.r*1.4,col,p.life*.85);}
    else{tc.save();tc.globalAlpha=p.life*.8;tc.fillStyle=col;tc.shadowColor=col;tc.shadowBlur=p.r*3;tc.beginPath();tc.arc(p.x,p.y,p.r,0,Math.PI*2);tc.fill();tc.restore();}
  }
  requestAnimationFrame(animTrail);
})();

/* Ring follow */
const ring = document.getElementById('cur-r');
(function loopRing(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(loopRing);})();

document.getElementById('nav-toggle')?.addEventListener('click',()=>{
  document.getElementById('mobile-menu').classList.toggle('open');
});

window.addEventListener('scroll',()=>{
  document.getElementById('nav').classList.toggle('scrolled',window.scrollY>55);
});
</script>