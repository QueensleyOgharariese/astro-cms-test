---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'Manga, manhwa, anime, style and music — honest reviews and curated picks.', image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
  <title>{title} — Little Confidants</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={`${title} — Little Confidants`} />
  <meta property="og:description" content={description} />
  {image && <meta property="og:image" content={image} />}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} — Little Confidants`} />
  <meta name="twitter:description" content={description} />

  <!-- Netlify Identity (for CMS) -->
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>

<!-- Cursor -->
<div id="cur"></div>
<div id="cur-r"></div>
<canvas id="trail-canvas"></canvas>
<canvas id="stars-canvas"></canvas>

<!-- Stained glass bg -->
<div id="sg-bg">
  <svg viewBox="0 0 100 100" preserveAspectRatio="xMidYMid slice"> 
    <defs> 
      <pattern id="p1" x="0" y="0" width="14" height="14" patternUnits="userSpaceOnUse"> 
        <polygon points="7,0 14,7 7,14 0,7" fill="none" stroke="rgba(224,0,154,1)" stroke-width=".22"/> 
      </pattern> 
      <pattern id="p2" x="0" y="0" width="28" height="28" patternUnits="userSpaceOnUse"> 
        <polygon points="14,0 28,14 14,28 0,14" fill="none" stroke="rgba(240,200,74,.75)" stroke-width=".18"/> 
        <circle cx="14" cy="14" r="2.5" fill="none" stroke="rgba(224,0,154,.55)" stroke-width=".18"/> 
      </pattern> 
    </defs> 
    <rect width="100" height="100" fill="url(#p1)"/> 
    <rect width="100" height="100" fill="url(#p2)"/> 
  </svg>
</div>
<div id="beams"></div>

<!-- NAVBAR -->
<nav id="nav">
  <a class="logo" href="/">
    <svg class="logo-rose" width="38" height="38" viewBox="0 0 80 80" fill="none">
      <!-- ...logo SVG content... -->
    </svg>
    <div class="logo-t">
      Little Confidants
      <span class="logo-s">manga · manhwa · anime · style</span>
    </div>
  </a>

  <div class="nav-links">
    <a class="nav-a" href="/">Home</a>
    <a class="nav-a" href="/blog">Blog</a>
    <a class="nav-a" href="/recs">Favorites</a>
    <a class="nav-cta" href="/about"><span>About</span></a>
  </div>

  <button class="nav-hamburger" id="nav-toggle" aria-label="Toggle menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="mobile-menu" id="mobile-menu">
  <a href="/" class="mobile-link">Home</a>
  <a href="/blog" class="mobile-link">Blog</a>
  <a href="/recs" class="mobile-link">Favorites</a>
  <a href="/about" class="mobile-link mobile-link-cta">About</a>
</div>

<main>
  <slot />
</main>

<!-- FOOTER -->
<footer id="site-footer">
  <div class="footer-top">
    <div class="footer-rule"></div>
    <div class="footer-mid">— Little Confidants —</div>
    <div class="footer-rule footer-rule-r"></div>
  </div>
  <div class="footer-bot">
    <div class="footer-brand">Little Confidants</div>
    <nav class="footer-links">
      <a href="/about" class="footer-link">About</a>
      <a href="/blog" class="footer-link">Blog</a>
      <a href="/recs" class="footer-link">Recs</a>
      <a href="/rss.xml" class="footer-link">RSS</a>
    </nav>
  </div>
</footer>

<style>
/* ── NAVBAR, FOOTER e STILI VARI ── */
#nav{position:fixed;top:0;left:0;right:0;z-index:2000;height:66px;padding:0 52px;display:flex;align-items:center;justify-content:space-between;background:rgba(26,8,32,.88);backdrop-filter:blur(28px);border-bottom:2px solid rgba(232,0,106,.25);transition:background .4s}
#nav.scrolled{background:rgba(26,8,32,.98) !important;border-color:rgba(255,120,190,.78)}
.logo{display:flex;align-items:center;gap:10px;cursor:pointer;text-decoration:none}
/* ...tutti gli altri stili esistenti ... */
main{position:relative;z-index:5;padding-top:66px}
</style>

<script>
// ── CURSOR TRAIL ──
const trailCvs = document.getElementById('trail-canvas') as HTMLCanvasElement;
const tc = trailCvs.getContext('2d')!;
let W = window.innerWidth, H = window.innerHeight;
trailCvs.width = W; trailCvs.height = H;
window.addEventListener('resize', () => { W = window.innerWidth; H = window.innerHeight; trailCvs.width = W; trailCvs.height = H; });

const trail: any[] = [];
let mx = W/2, my = H/2, rx = mx, ry = my;

document.addEventListener('mousemove', e => {
  mx = e.clientX; my = e.clientY;
  for (let i = 0; i < 3; i++) {
    trail.push({ x: mx+(Math.random()-.5)*8, y: my+(Math.random()-.5)*8, r: 1.5+Math.random()*3, life: 1, decay: .045+Math.random()*.035, vx: (Math.random()-.5)*.8, vy: (Math.random()-.5)*.8-.5, hue: Math.random()>.5?315:280, isStar: Math.random()>.7 });
  }
  if (trail.length > 80) trail.splice(0, trail.length - 80);
  document.getElementById('cur')!.style.left = mx + 'px';
  document.getElementById('cur')!.style.top = my + 'px';
});

function drawStar(cx:number,cy:number,r:number,col:string,a:number) {
  tc.save(); tc.globalAlpha=a; tc.fillStyle=col; tc.translate(cx,cy); tc.beginPath();
  for(let i=0;i<5;i++){const a1=-Math.PI/2+(i*4*Math.PI/5),a2=-Math.PI/2+((i*4+2)*Math.PI/5);tc.lineTo(Math.cos(a1)*r,Math.sin(a1)*r);tc.lineTo(Math.cos(a2)*r*.42,Math.sin(a2)*r*.42);}
  tc.closePath(); tc.fill(); tc.restore();
}

(function animTrail() {
  tc.clearRect(0,0,W,H);
  for(let i=trail.length-1;i>=0;i--){
    const p=trail[i]; p.x+=p.vx; p.y+=p.vy; p.vy+=.015; p.life-=p.decay;
    if(p.life<=0){trail.splice(i,1);continue;}
    const col=`hsl(${p.hue},100%,65%)`;
    if(p.isStar){drawStar(p.x,p.y,p.r*1.4,col,p.life*.85);}
    else{tc.save();tc.globalAlpha=p.life*.8;tc.fillStyle=col;tc.shadowColor=col;tc.shadowBlur=p.r*3;tc.beginPath();tc.arc(p.x,p.y,p.r,0,Math.PI*2);tc.fill();tc.restore();}
  }
  requestAnimationFrame(animTrail);
})();

// Ring follow
const ring = document.getElementById('cur-r')!;
(function loopRing(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(loopRing);})();
document.querySelectorAll('a,button,.btn,.post-card,.cat,.tag-pill').forEach(el=>{
  el.addEventListener('mouseenter',()=>{ring.style.width='46px';ring.style.height='46px';ring.style.borderColor='rgba(255,0,200,.72)';});
  el.addEventListener('mouseleave',()=>{ring.style.width='34px';ring.style.height='34px';ring.style.borderColor='rgba(255,0,200,.3)';});
});

// Falling stars, beams, marquee, stained glass strip, nav scroll, mobile menu
// (mantieni il tuo codice esistente senza loader)

// ── NETLIFY IDENTITY ──
if((window as any).netlifyIdentity){
  (window as any).netlifyIdentity.on('init', (user:any) => {
    if(!user){(window as any).netlifyIdentity.on('login',()=>{document.location.href='/admin/';})}
  });
}
</script>
</body>
</html>